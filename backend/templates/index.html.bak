                    </div>
                    <div class="small text-center" id="highcpu-sim-detail-text" style="color:rgba(255,255,255,0.5);">
                      Inject an error to begin live simulation.
                    </div>
                  </div>
                </div>
              </div>

              <div class="card card-modern mb-4" id="timelineAndMetricsCard">
                <div class="card-header bg-gradient-success border-0 d-flex justify-content-between align-items-center">
                  <h5 class="mb-0 text-white">
                    <i class="fas fa-project-diagram me-2"></i>Execution Timeline
                  </h5>
                  <span class="badge bg-dark" id="sim-summary-badge">No run yet</span>
                </div>
                <div class="card-body">
                  <div class="sim-metrics-grid mb-3" id="sim-metrics-grid">
                    <div class="sim-metric-card">
                      <div class="sim-metric-label">Resolved Incidents</div>
                      <div class="sim-metric-value" id="sim-metric-resolved">0</div>
                    </div>
                    <div class="sim-metric-card">
                      <div class="sim-metric-label">Escalated Incidents</div>
                      <div class="sim-metric-value" id="sim-metric-escalated">0</div>
                    </div>
                    <div class="sim-metric-card">
                      <div class="sim-metric-label">Retries</div>
                      <div class="sim-metric-value" id="sim-metric-retries">0</div>
                    </div>
                    <div class="sim-metric-card">
                      <div class="sim-metric-label">Mean Recovery (s)</div>
                      <div class="sim-metric-value" id="sim-metric-mttr">0</div>
                    </div>
                  </div>
                  <div class="simulation-timeline" id="sim-timeline">
                    <div class="text-muted">Run the simulation to see step-by-step flow.</div>
                  </div>
                </div>
              </div>

              <div class="card card-modern mb-4">
                <div class="card-header bg-gradient-info border-0">
                  <h5 class="mb-0 text-white">
                    <i class="fas fa-list-check me-2"></i>Event + Rule Result
                  </h5>
                </div>
                <div class="card-body">
                  <div id="sim-result-cards" class="d-flex flex-column gap-2">
                    <div class="text-muted">No simulation result yet.</div>
                  </div>
                </div>
              </div>

              <div class="card card-modern">
                <div class="card-header bg-gradient-secondary border-0">
                  <h5 class="mb-0 text-white">
                    <i class="fas fa-terminal me-2"></i>Simulated Script Output
                  </h5>
                </div>
                <div class="card-body">
                  <pre class="simulation-log" id="sim-terminal-output">No simulation output yet.</pre>
                </div>
              </div>
            </div>
          </div>
          </div>
        </div>
      </div>
    </div>
  </div>


  <!-- Rule Create/Edit Modal -->
  <div class="modal fade" tabindex="-1" id="ruleModal">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content modal-modern">
        <div class="modal-header bg-gradient-info border-0">
          <h5 class="modal-title text-white" id="ruleModalTitle">
            <i class="fas fa-plus-circle me-2"></i>Create Rule
          </h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <form id="rule-form">
            <input type="hidden" id="rule-id" />
            <div class="row g-3">
              <div class="col-md-8">
                <label class="form-label fw-500">Rule Name *</label>
                <input class="form-control form-control-modern" id="rule-name"
                  placeholder="Enter a descriptive rule name" required />
              </div>
              <div class="col-md-4">
                <label class="form-label fw-500">Event ID</label>
                <input class="form-control form-control-modern" id="rule-event_id" placeholder="e.g. 7034" />
              </div>
              <div class="col-md-6">
                <label class="form-label fw-500">Source</label>
                <input class="form-control form-control-modern" id="rule-source"
                  placeholder="e.g. Service Control Manager" />
              </div>
              <div class="col-md-6">
                <label class="form-label fw-500">Message Regex</label>
                <input class="form-control form-control-modern" id="rule-message_regex"
                  placeholder="Optional regex pattern" />
              </div>
              <div class="col-12">
                <label class="form-label fw-500">Remediation Script</label>
                <div class="btn-group w-100 mb-2" role="group">
                  <input type="radio" class="btn-check" name="script-type-radio" id="script-type-file" value="file"
                    checked />
                  <label class="btn btn-outline-secondary btn-sm" for="script-type-file">
                    <i class="fas fa-file me-1"></i>File Path
                  </label>
                  <input type="radio" class="btn-check" name="script-type-radio" id="script-type-inline"
                    value="inline" />
                  <label class="btn btn-outline-primary btn-sm" for="script-type-inline">
                    <i class="fas fa-code me-1"></i>Inline Script
                  </label>
                </div>
                <textarea class="form-control form-control-modern font-monospace" id="rule-remediation_script" rows="6"
                  placeholder="C:\scripts\fix.ps1" style="font-size: 0.85rem; resize: vertical;"></textarea>
                <small class="text-muted mt-1 d-block">
                  <i class="fas fa-info-circle me-1"></i>
                  <span id="script-hint-text">Enter the full path to a .ps1 file on this machine.</span>
                </small>
              </div>
              <div class="col-md-6">
                <div class="form-check">
                  <input type="checkbox" class="form-check-input" id="rule-auto" />
                  <label class="form-check-label" for="rule-auto">Enable Auto-Remediation</label>
                  <small class="d-block text-muted mt-1">When enabled, the script runs automatically on every matching event</small>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-check">
                  <input type="checkbox" class="form-check-input" id="rule-stop_processing" />
                  <label class="form-check-label text-warning fw-500" for="rule-stop_processing" title="Rule Short-circuiting">
                    <i class="fas fa-hand-paper me-1"></i>Stop Processing Further Rules
                  </label>
                  <small class="d-block text-muted mt-1">If this rule matches, engine will skip any lower-priority rules for this event.</small>
                </div>
              </div>
              <!-- Intelligence fields -->
              <div class="col-md-6">
                <label class="form-label fw-500">
                  <i class="fas fa-sort-numeric-up me-1 text-primary"></i>Priority
                  <small class="text-muted ms-1">(lower = runs first)</small>
                </label>
                <input type="number" class="form-control form-control-modern" id="rule-priority"
                  min="1" max="999" value="100" placeholder="100" />
                <small class="text-muted">When multiple rules match one event, lower priority value runs first.</small>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-500">
                  <i class="fas fa-clock me-1 text-warning"></i>Cooldown
                  <small class="text-muted ms-1">(minutes, 0 = off)</small>
                </label>
                <input type="number" class="form-control form-control-modern" id="rule-cooldown"
                  min="0" max="1440" value="0" placeholder="0" />
                <small class="text-muted">Suppress auto-remediation re-runs for this duration after each execution.</small>
              </div>
            </div>
          </form>
        </div>
        <div class="modal-footer" style="background:var(--glass-bg); border-top:1px solid var(--glass-border);">
          <button class="btn btn-outline-secondary" id="rule-reset" type="button">
            <i class="fas fa-redo me-1"></i>Reset
          </button>
          <button class="btn btn-primary btn-modern" id="rule-save-btn" type="button">
            <i class="fas fa-save me-1"></i>Save Rule
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Matches Modal -->
  <div class="modal fade" tabindex="-1" id="matchesModal">
    <div class="modal-dialog modal-lg">
      <div class="modal-content modal-modern">
        <div class="modal-header bg-gradient-primary border-0">
          <h5 class="modal-title text-white">
            <i class="fas fa-link me-2"></i>Matching Rules for Event <span id="modal-event-id"></span>
          </h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div id="matches-list"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Status Badge Modal -->
  <div class="modal fade" tabindex="-1" id="statusModal">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-modern text-center">
        <div class="modal-body p-4">
          <div id="status-content"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Simulation Preferences Modal -->
  <div class="modal fade" tabindex="-1" id="simulationPreferencesModal" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-modern">
        <div class="modal-header bg-gradient-primary border-0">
          <h5 class="modal-title text-white">
            <i class="fas fa-flask me-2"></i>Simulation Preferences
          </h5>
        </div>
        <div class="modal-body">
          <p class="mb-3">Configure your simulation preferences:</p>
          <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" id="simPrefRunScript" checked />
            <label class="form-check-label" for="simPrefRunScript">
              <strong>Run the remediation script</strong>
              <div class="small text-muted">Execute the fix script when running simulations</div>
            </label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="simPrefAutoRemediate" checked />
            <label class="form-check-label" for="simPrefAutoRemediate">
              <strong>Auto-remediate on future runs</strong>
              <div class="small text-muted">Remember this choice and use it automatically next time</div>
            </label>
          </div>
          <div class="alert alert-info mt-3 mb-0">
            <i class="fas fa-info-circle me-2"></i>
            You can change these preferences anytime by running a new simulation.
          </div>
        </div>
        <div class="modal-footer border-top">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" id="simPrefSkipBtn">
            <i class="fas fa-times me-1"></i>Skip Simulation
          </button>
          <button type="button" class="btn btn-primary" id="simPrefConfirmBtn">
            <i class="fas fa-check me-1"></i>Continue
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════
       LIVE ALERT POPUP — floats fixed bottom-right on the Dashboard
       Shown automatically when /api/alerts/live returns new alerts.
       ═══════════════════════════════════════════════════════════════════ -->
  <div id="live-alert-popup" style="
       display:none;
       position:fixed;
       bottom:28px;
       right:28px;
       z-index:9999;
       width:380px;
       border-radius:16px;
       overflow:hidden;
       box-shadow:0 8px 40px rgba(255,78,80,0.35),0 2px 12px rgba(0,0,0,0.4);
       animation:slideUpPop 0.4s cubic-bezier(0.34,1.56,0.64,1) both;
       font-family:inherit;">
    <!-- Header bar -->
    <div id="live-alert-popup-header" style="
         background:linear-gradient(135deg,#ff4e50,#f9d423);
         padding:14px 18px 10px;
         display:flex;
         align-items:center;
         justify-content:space-between;">
      <div style="display:flex;align-items:center;gap:10px;">
        <span style="font-size:1.4rem;" id="lap-icon">⚠️</span>
        <div>
          <div style="font-weight:700;color:#fff;font-size:0.95rem;" id="lap-title">High CPU Alert Detected</div>
          <div style="font-size:0.72rem;color:rgba(255,255,255,0.85);" id="lap-subtitle">Event 9999 · AutoRemediationDemo</div>
        </div>
      </div>
      <button onclick="dismissLiveAlert()" style="
          background:rgba(0,0,0,0.15);border:none;color:#fff;
          border-radius:50%;width:28px;height:28px;cursor:pointer;
          font-size:0.85rem;display:flex;align-items:center;justify-content:center;">&times;</button>
    </div>
    <!-- Body -->
    <div style="background:#1a1a2e;padding:14px 18px;">
      <div style="font-size:0.8rem;color:rgba(255,255,255,0.7);margin-bottom:12px;line-height:1.5;" id="lap-message">
        CPU spike detected on DemoWorkload.exe
      </div>
      <!-- CPU mini-bar -->
      <div style="margin-bottom:14px;">
        <div style="display:flex;justify-content:space-between;font-size:0.72rem;color:rgba(255,255,255,0.5);margin-bottom:4px;">
          <span>CPU Usage</span><span id="lap-cpu-pct" style="color:#fc913a;font-weight:600;">—%</span>
        </div>
        <div style="height:6px;background:rgba(255,255,255,0.1);border-radius:3px;overflow:hidden;">
          <div id="lap-cpu-bar" style="height:100%;width:0%;background:linear-gradient(90deg,#fc913a,#ff4e50);border-radius:3px;transition:width 0.6s ease;"></div>
        </div>
      </div>
      <!-- Timestamp -->
      <div style="font-size:0.7rem;color:rgba(255,255,255,0.4);margin-bottom:14px;" id="lap-timestamp"></div>
      <!-- Action buttons -->
      <div id="lap-actions" style="display:flex;gap:10px;">
        <button id="lap-remediate-btn" onclick="remediateFromPopup()" style="
            flex:1;padding:9px 0;background:linear-gradient(135deg,#28a745,#20c997);
            border:none;color:#fff;border-radius:10px;font-weight:600;
            font-size:0.85rem;cursor:pointer;transition:opacity 0.2s;">
          ⚡ Auto-Remediate Now
        </button>
        <button onclick="dismissLiveAlert()" style="
            padding:9px 14px;background:rgba(255,255,255,0.07);
            border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.7);
            border-radius:10px;font-size:0.85rem;cursor:pointer;">
          Dismiss
        </button>
      </div>
      <!-- Remediation progress (hidden until clicked) -->
      <div id="lap-progress-wrap" style="display:none;margin-top:12px;">
        <div style="background:rgba(255,255,255,0.07);border-radius:8px;height:6px;overflow:hidden;margin-bottom:6px;">
          <div id="lap-progress-bar" style="height:100%;width:0%;background:linear-gradient(90deg,#28a745,#20c997);border-radius:8px;transition:width 1.2s ease;"></div>
        </div>
        <div style="font-size:0.75rem;color:rgba(255,255,255,0.55);text-align:center;" id="lap-progress-text">Executing remediation script...</div>
      </div>
    </div>
  </div>

  <style>
  @keyframes slideUpPop {
    from { opacity:0; transform:translateY(40px) scale(0.94); }
    to   { opacity:1; transform:translateY(0)   scale(1); }
  }
  @keyframes pulseGlow {
    0%,100% { box-shadow:0 8px 40px rgba(255,78,80,0.35),0 2px 12px rgba(0,0,0,0.4); }
    50%      { box-shadow:0 8px 60px rgba(255,78,80,0.55),0 2px 16px rgba(0,0,0,0.5); }
  }
  #live-alert-popup.pulsing { animation: slideUpPop 0.4s cubic-bezier(0.34,1.56,0.64,1) both, pulseGlow 2s ease-in-out 0.4s 3; }
  #live-alert-popup.remediated-state { box-shadow:0 8px 40px rgba(40,167,69,0.4),0 2px 12px rgba(0,0,0,0.4); }
  #live-alert-popup.remediated-state #live-alert-popup-header { background:linear-gradient(135deg,#28a745,#20c997) !important; }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let _simulationInProgress = false;
    let _pendingSimulation = null;

    async function api(path, opts) {
      const res = await fetch(path, opts);
      if (!res.ok) throw new Error(await res.text());
      return res.json();
    }

    function showStatus(title, message, type = 'info') {
      const content = document.getElementById('status-content');
      const typeClass = `text-${type === 'success' ? 'success' : type === 'error' ? 'danger' : type === 'warning' ? 'warning' : 'info'}`;
      const icon = type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : type === 'warning' ? 'fa-warning' : 'fa-info-circle';
      content.innerHTML = `
    <i class="fas ${icon} ${typeClass}" style="font-size: 3rem; margin-bottom: 1rem;"></i>
    <h5>${title}</h5>
    <p class="text-muted">${message}</p>
  `;
      const modal = new bootstrap.Modal(document.getElementById('statusModal'));
      modal.show();
    }

    async function checkSimulationPreference(simType) {
      try {
        const resp = await api(`/api/simulations/preferences/${simType}`);
        return resp.has_preference ? resp.preference : null;
      } catch (e) {
        console.warn('Could not fetch preference:', e);
        return null;
      }
    }

    async function saveSimulationPreference(simType, runScript, autoRemediate) {
      try {
        await api(`/api/simulations/preferences/${simType}`, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({run_script: runScript, auto_remediate: autoRemediate})
        });
      } catch (e) {
        console.warn('Could not save preference:', e);
      }
    }

    async function showSimulationPreferencesModal(simType, callback) {
      return new Promise((resolve) => {
        const prefRunScript = document.getElementById('simPrefRunScript');
        const prefAutoRemediate = document.getElementById('simPrefAutoRemediate');
        const prefConfirmBtn = document.getElementById('simPrefConfirmBtn');
        const prefSkipBtn = document.getElementById('simPrefSkipBtn');
        const modal = new bootstrap.Modal(document.getElementById('simulationPreferencesModal'));

        prefRunScript.checked = true;
        prefAutoRemediate.checked = true;

        prefConfirmBtn.onclick = async () => {
          const runScript = prefRunScript.checked;
          const autoRemediate = prefAutoRemediate.checked;
          await saveSimulationPreference(simType, runScript, autoRemediate);
          modal.hide();
          resolve({run_script: runScript, auto_remediate: autoRemediate});
        };

        prefSkipBtn.onclick = () => {
          modal.hide();
          resolve(null);
        };

        modal.show();
      });
    }

    function getStatusBadge(status) {
      const badges = {
        'success':   '<span class="badge bg-success"><i class="fas fa-check me-1"></i>Success</span>',
        'failed':    '<span class="badge bg-danger"><i class="fas fa-times me-1"></i>Failed</span>',
        'error':     '<span class="badge bg-danger"><i class="fas fa-exclamation me-1"></i>Error</span>',
        'pending':   '<span class="badge bg-warning"><i class="fas fa-clock me-1"></i>Pending</span>',
        'approved':  '<span class="badge bg-success"><i class="fas fa-thumbs-up me-1"></i>Approved</span>',
        'denied':    '<span class="badge bg-secondary"><i class="fas fa-ban me-1"></i>Denied</span>',
        'skipped':   '<span class="badge bg-info"><i class="fas fa-forward me-1"></i>Skipped</span>',
        'suppressed':'<span class="badge" style="background:#9d4edd"><i class="fas fa-pause me-1"></i>Suppressed</span>',
      };
      return badges[status] || `<span class="badge bg-secondary">${status}</span>`;
    }

    // Returns a color-coded confidence badge (0-100)
    function getConfidenceBadge(score) {
      const s = parseFloat(score) || 0;
      if (s >= 70) return `<span class="badge" style="background:#dc3545;font-weight:600" title="High urgency">${s}</span>`;
      if (s >= 40) return `<span class="badge" style="background:#fd7e14;font-weight:600" title="Medium urgency">${s}</span>`;
      if (s > 0)   return `<span class="badge" style="background:#6c757d;font-weight:600" title="Low urgency">${s}</span>`;
      return `<span class="badge bg-secondary" title="Unscored">—</span>`;
    }

    function getSeverityBadge(severity) {
      if (!severity) return '<span class="badge bg-secondary">Unknown</span>';
      const badges = {
        'Critical': '<span class="badge bg-danger"><i class="fas fa-circle-exclamation me-1"></i>Critical</span>',
        'High': '<span class="badge bg-warning"><i class="fas fa-exclamation-triangle me-1"></i>High</span>',
        'Medium': '<span class="badge bg-info"><i class="fas fa-circle-question me-1"></i>Medium</span>',
        'Low': '<span class="badge bg-secondary"><i class="fas fa-circle-info me-1"></i>Low</span>',
        'Info': '<span class="badge bg-light text-dark"><i class="fas fa-circle-info me-1"></i>Info</span>'
      };
      return badges[severity] || `<span class="badge bg-secondary">${severity}</span>`;
    }

    function getLevelBadge(level) {
      if (!level) return '<span class="badge bg-secondary">Unknown</span>';
      const levelLower = level.toLowerCase();
      if (levelLower === 'error') {
        return '<span class="badge bg-danger"><i class="fas fa-times-circle me-1"></i>Error</span>';
      } else if (levelLower === 'warning') {
        return '<span class="badge bg-warning text-dark"><i class="fas fa-exclamation-triangle me-1"></i>Warning</span>';
      }
      return `<span class="badge bg-secondary">${level}</span>`;
    }

    function getCategoryBadge(category) {
      if (!category) return '<span class="badge-category unknown"><i class="fas fa-tag me-1"></i>Unknown</span>';

      const categoryLower = category.toLowerCase();
      const categoryMap = {
        // Service-related
        'service failure': 'service-failure',
        'service startup failure': 'service-failure',
        'service terminated': 'service-failure',
        'dependency failure': 'service-failure',
        'service control manager': 'service-failure',

        // Disk-related
        'low disk space': 'disk-issue',
        'disk i/o error': 'disk-issue',
        'disk': 'disk-issue',
        'storage': 'disk-issue',

        // Security-related
        'security': 'security',
        'authentication': 'security',
        'permission': 'security',
        'access denied': 'security',
        'account lockout': 'security',

        // Network-related
        'network': 'network',
        'connectivity': 'network',
        'dns': 'network',
        'tcp/ip': 'network',
        'internet': 'network',

        // System-related
        'system': 'system',
        'shutdown': 'system',
        'boot': 'system',
        'driver': 'driver',
        'device': 'system',

        // Application-related
        'application': 'application',
        'app': 'application',
        'program': 'application',
        'software': 'application',

        // Memory-related
        'memory': 'memory',
        'ram': 'memory',
        'heap': 'memory',
        'virtual memory': 'memory',

        // Registry-related
        'registry': 'registry',
        'configurations': 'registry'
      };

      // Find matching category color
      let colorClass = 'unknown';
      for (const [key, value] of Object.entries(categoryMap)) {
        if (categoryLower.includes(key)) {
          colorClass = value;
          break;
        }
      }

      const icons = {
        'service-failure': 'fa-cogs',
        'disk-issue': 'fa-hard-drive',
        'security': 'fa-lock',
        'network': 'fa-network-wired',
        'system': 'fa-computer',
        'application': 'fa-cube',
        'memory': 'fa-microchip',
        'driver': 'fa-plug',
        'registry': 'fa-database',
        'unknown': 'fa-tag'
      };

      const icon = icons[colorClass] || 'fa-tag';
      return `<span class="badge-category ${colorClass} fw-bold"><i class="fas ${icon} me-1"></i>${category}</span>`;
    }

    // Events tab removed - focusing only on errors and warnings

    async function showMatches(event) {
      // Accept either a full event object (from CSV rows) or a plain DB row id
      const isEventObj = typeof event === 'object' && event !== null;
      const winEventId = isEventObj ? event.event_id : event;
      document.getElementById('modal-event-id').textContent = winEventId;
      try {
        // Ensure the event exists in the DB and get its row id
        let dbEventRowId;
        if (isEventObj) {
          const ensureResult = await api('/api/events/ensure', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(event)
          });
          dbEventRowId = ensureResult.event_row_id;
        } else {
          dbEventRowId = event;
        }

        const matches = await api(`/api/events/${dbEventRowId}/matches`);
        const div = document.getElementById('matches-list');
        div.innerHTML = '';
        if (matches.length === 0) {
          div.innerHTML = '<div class="alert alert-info"><i class="fas fa-info-circle me-2"></i>No matching rules found for this event</div>';
        } else {
          for (const m of matches) {
            const criteria = [];
            if (m.event_id) criteria.push(`Event: <code>${m.event_id}</code>`);
            if (m.source) criteria.push(`Source: <code>${m.source}</code>`);
            if (m.message_regex) criteria.push(`Regex: <code>${m.message_regex}</code>`);

            const card = document.createElement('div');
            card.className = 'card mb-3 border-left-primary';
            card.innerHTML = `
          <div class="card-body">
            <div class="row align-items-center">
              <div class="col">
                <h6 class="mb-2"><strong>${m.name}</strong></h6>
                ${m.severity ? `<div class="mb-1">${getSeverityBadge(m.severity)} ${m.category ? getCategoryBadge(m.category) : ''}</div>` : ''}
                ${m.description ? `<div class="small mb-2"><strong>Description:</strong> ${m.description}</div>` : ''}
                ${m.recommended_action ? `<div class="small mb-2"><strong>Recommended Action:</strong> ${m.recommended_action}</div>` : ''}
                <div class="small text-muted">
                  ${criteria.length > 0 ? criteria.join(' &bull; ') : 'Matches all events'}
                </div>
              </div>
              <div class="col-auto d-flex gap-2">
                <button class="btn btn-sm btn-success" onclick="runRule(${m.id}, ${dbEventRowId}, this)">
                  <i class="fas fa-play me-1"></i>Run Now
                </button>
                <button class="btn btn-sm btn-warning" onclick="requestRun(${m.id}, ${dbEventRowId}, this)">
                  <i class="fas fa-shield-alt me-1"></i>Request
                </button>
              </div>
            </div>
          </div>
        `;
            div.appendChild(card);
          }
        }
        var myModal = new bootstrap.Modal(document.getElementById('matchesModal'));
        myModal.show();
      } catch (e) {
        showStatus('Error', 'Failed to load matching rules: ' + e.message, 'error');
      }
    }

    async function runRule(ruleId, eventId, btn) {
      btn.disabled = true;
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Running...';
      try {
        const res = await api(`/api/rules/${ruleId}/run`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ event_row_id: eventId }) });
        const output = res.output ? res.output.substring(0, 300) : 'No output';
        showStatus('Execution Complete', `Status: <strong>${res.status}</strong><br><pre class="text-start mt-3" style="max-height: 200px; overflow: auto; font-size: 0.85rem;">${output}</pre>`, res.status === 'success' ? 'success' : 'error');
        loadHistory();
        loadDashboard();
      } catch (e) {
        showStatus('Error', 'Failed to run remediation: ' + e.message, 'error');
      }
      btn.disabled = false;
      btn.innerHTML = originalText;
    }

    async function testRule(ruleId) {
      if (!confirm('Run a test execution of this rule? A synthetic test event will be created in the DB.')) return;
      try {
        showStatus('Running', 'Executing test run…', 'info');
        const res = await api(`/api/rules/${ruleId}/test`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({}) });
        const output = res.output ? res.output.substring(0, 300) : 'No output';
        showStatus('Test Run Complete', `Status: <strong>${res.status}</strong><br><pre class="text-start mt-3" style="max-height: 200px; overflow: auto; font-size: 0.85rem;">${output}</pre>`, res.status === 'success' ? 'success' : 'error');
        loadHistory();
        loadDashboard();
      } catch (e) {
        showStatus('Error', 'Test run failed: ' + e.message, 'error');
      }
    }

    async function requestRun(ruleId, eventId, btn) {
      btn.disabled = true;
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="fas fa-clock me-1"></i>Requesting...';
      try {
        await api('/api/requests', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ event_row_id: eventId, rule_id: ruleId, requested_by: 'web-ui' }) });
        showStatus('Request Submitted', 'Approval request has been created and is pending review.', 'success');
        loadRequests();
        loadHistory();
      } catch (e) {
        showStatus('Error', 'Failed to submit request: ' + e.message, 'error');
        btn.disabled = false;
        btn.innerHTML = originalText;
      }
    }

    async function loadRequests() {
      try {
        const rows = await api('/api/requests?status=pending');
        const tbody = document.querySelector('#approvals-table tbody');
        const noApprovals = document.getElementById('no-approvals');
        tbody.innerHTML = '';

        if (rows.length === 0) {
          noApprovals.style.display = 'block';
          return;
        }
        noApprovals.style.display = 'none';

        for (const r of rows) {
          const tr = document.createElement('tr');
          tr.innerHTML = `
        <td><span class="badge bg-primary">${r.id}</span></td>
        <td><code>${r.event_id || r.event_row_id}</code></td>
        <td><strong>${r.rule_name || r.rule_id}</strong></td>
        <td>${r.requested_by}</td>
        <td><small class="text-muted">${new Date(r.requested_at).toLocaleString()}</small></td>
        <td>${getStatusBadge(r.status)}</td>
        <td class="text-center">
          <button class="btn btn-sm btn-success" onclick="approveRequest(${r.id}, this)">
            <i class="fas fa-check me-1"></i>Approve
          </button>
          <button class="btn btn-sm btn-danger" onclick="denyRequest(${r.id}, this)">
            <i class="fas fa-times me-1"></i>Deny
          </button>
        </td>
      `;
          tbody.appendChild(tr);
        }
      } catch (e) {
        console.error('Failed to load requests:', e);
      }
    }

    async function approveRequest(id, btn) {
      if (!confirm('Approve this remediation request?')) return;
      btn.disabled = true;
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Approving...';
      try {
        const res = await api(`/api/requests/${id}/approve`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ processed_by: 'admin' }) });
        const output = res.result.output ? res.result.output.substring(0, 300) : 'No output';
        showStatus('Request Approved', `Remediation executed successfully.<br><pre class="text-start mt-3" style="max-height: 200px; overflow: auto; font-size: 0.85rem;">${output}</pre>`, 'success');
      } catch (e) {
        showStatus('Error', 'Failed to approve request: ' + e.message, 'error');
      }
      loadRequests(); loadHistory(); loadFilteredEvents();
    }

    async function denyRequest(id, btn) {
      if (!confirm('Deny this remediation request?')) return;
      btn.disabled = true;
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Denying...';
      try {
        await api(`/api/requests/${id}/deny`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ processed_by: 'admin', note: 'Denied by admin' }) });
        showStatus('Request Denied', 'The remediation request has been denied.', 'info');
      } catch (e) {
        showStatus('Error', 'Failed to deny request: ' + e.message, 'error');
      }
      loadRequests();
    }

    // Rules Management
    async function loadRules() {
      try {
        const rules = await api('/api/rules');
        const tbody = document.querySelector('#rules-table tbody');
        tbody.innerHTML = '';
        if (rules.length === 0) {
          tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4">No rules configured. Click "Import from JSON" to load predefined rules.</td></tr>';
          return;
        }
        for (const r of rules) {
          const tr = document.createElement('tr');
          const criteria = [];
          if (r.event_id) criteria.push(`Event: <code>${r.event_id}</code>`);
          if (r.source)   criteria.push(`Source: <code>${r.source}</code>`);
          const title = r.description ? `title="${r.description}"` : '';
          const priorityBadge = `<span class="badge ${r.priority <= 50 ? 'bg-danger' : r.priority <= 100 ? 'bg-primary' : 'bg-secondary'}" title="Priority">${r.priority ?? 100}</span>`;
          const cooldownBadge = r.cooldown_minutes > 0
            ? `<span class="badge" style="background:#fd7e14" title="Auto-run suppressed for ${r.cooldown_minutes} min after each run"><i class="fas fa-clock me-1"></i>${r.cooldown_minutes}m</span>`
            : `<span class="badge bg-secondary">Off</span>`;
          tr.innerHTML = `
        <td ${title}>
          <strong>${r.name}</strong>
          ${r.category ? `<br>${getCategoryBadge(r.category)}` : ''}
          ${r.stop_processing ? '<br><span class="badge bg-warning text-dark mt-1" title="Stops processing lower priority rules"><i class="fas fa-hand-paper me-1"></i>Terminal</span>' : ''}
        </td>
        <td class="text-center">${priorityBadge}</td>
        <td><small>${criteria.length > 0 ? criteria.join('<br>') : '<em>All events</em>'}</small></td>
        <td>${r.severity ? getSeverityBadge(r.severity) : '<span class="badge bg-secondary">N/A</span>'}</td>
        <td>${r.auto_remediate ? '<span class="badge bg-success">Yes</span>' : '<span class="badge bg-secondary">No</span>'}</td>
        <td class="text-center">${cooldownBadge}</td>
        <td class="text-center">
          <button class="btn btn-sm btn-outline-success" onclick="testRule(${r.id})" title="Run a test execution of this rule">
            <i class="fas fa-play me-1"></i>Test
          </button>
          <button class="btn btn-sm btn-outline-secondary" onclick='editRule(${JSON.stringify(r)})'>
            <i class="fas fa-edit me-1"></i>Edit
          </button>
          <button class="btn btn-sm btn-outline-danger" onclick="deleteRule(${r.id})">
            <i class="fas fa-trash me-1"></i>Delete
          </button>
        </td>
      `;
          tbody.appendChild(tr);
        }
      } catch (e) {
        console.error('Failed to load rules:', e);
      }
    }

    function editRule(r) {
      document.getElementById('rule-id').value = r.id;
      document.getElementById('rule-name').value = r.name;
      document.getElementById('rule-event_id').value = r.event_id || '';
      document.getElementById('rule-source').value = r.source || '';
      document.getElementById('rule-message_regex').value = r.message_regex || '';
      document.getElementById('rule-remediation_script').value = r.remediation_script || '';
      document.getElementById('rule-auto').checked = r.auto_remediate;
      document.getElementById('rule-stop_processing').checked = r.stop_processing || false;
      document.getElementById('rule-priority').value = r.priority ?? 100;
      document.getElementById('rule-cooldown').value  = r.cooldown_minutes ?? 0;
      const scriptType = r.script_type || 'file';
      document.getElementById(scriptType === 'inline' ? 'script-type-inline' : 'script-type-file').checked = true;
      updateScriptTypeHint(scriptType);
      document.getElementById('ruleModalTitle').innerHTML = '<i class="fas fa-edit me-2"></i>Edit Rule';
      new bootstrap.Modal(document.getElementById('ruleModal')).show();
    }

    function openNewRuleModal() {
      document.getElementById('rule-form').reset();
      document.getElementById('rule-id').value = '';
      document.getElementById('rule-priority').value = 100;
      document.getElementById('rule-cooldown').value  = 0;
      updateScriptTypeHint('file');
      document.getElementById('ruleModalTitle').innerHTML = '<i class="fas fa-plus-circle me-2"></i>Create Rule';
      new bootstrap.Modal(document.getElementById('ruleModal')).show();
    }

    function updateScriptTypeHint(type) {
      const textarea = document.getElementById('rule-remediation_script');
      const hintText = document.getElementById('script-hint-text');
      if (type === 'inline') {
        textarea.placeholder = 'Write-Output "Remediation complete for $env:RM_EVENT_ID"\nRestart-Service -Name "MyService"';
        hintText.innerHTML = 'Enter PowerShell commands directly. <br><span class="text-primary mt-1 d-inline-block"><i class="fas fa-magic me-1"></i>Available variables: <code>$env:RM_EVENT_ID</code>, <code>$env:RM_SOURCE</code>, <code>$env:RM_MESSAGE</code>, <code>$env:RM_SEVERITY</code>, plus any regex captures like <code>$env:RM_MATCH_GroupName</code></span>';
      } else {
        textarea.placeholder = 'C:\\scripts\\fix.ps1';
        hintText.innerHTML = 'Enter the full path to a .ps1 file on this machine. <br><span class="text-primary mt-1 d-inline-block"><i class="fas fa-magic me-1"></i>Event is passed via environment variables (e.g. <code>$env:RM_EVENT_ID</code>).</span>';
      }
    }

    document.querySelectorAll('input[name="script-type-radio"]').forEach(radio => {
      radio.addEventListener('change', (e) => updateScriptTypeHint(e.target.value));
    });

    // Rule Save button (in modal)
    document.getElementById('rule-save-btn').addEventListener('click', async () => {
      const nameField = document.getElementById('rule-name');
      if (!nameField.value.trim()) { nameField.focus(); return; }
      const btn = document.getElementById('rule-save-btn');
      btn.disabled = true;
      const originalText = btn.innerHTML;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Saving...';

      const selectedType = document.querySelector('input[name="script-type-radio"]:checked')?.value || 'file';
      try {
        const payload = {
          name: document.getElementById('rule-name').value,
          event_id: document.getElementById('rule-event_id').value || null,
          source: document.getElementById('rule-source').value || null,
          message_regex: document.getElementById('rule-message_regex').value || null,
          remediation_script: document.getElementById('rule-remediation_script').value || null,
          script_type: selectedType,
          auto_remediate: document.getElementById('rule-auto').checked,
          stop_processing: document.getElementById('rule-stop_processing').checked,
          priority: parseInt(document.getElementById('rule-priority').value) || 100,
          cooldown_minutes: parseInt(document.getElementById('rule-cooldown').value) || 0,
        };
        const ruleId = document.getElementById('rule-id').value;
        if (ruleId) {
          await api(`/api/rules/${ruleId}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        } else {
          await api('/api/rules', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
        }
        bootstrap.Modal.getInstance(document.getElementById('ruleModal'))?.hide();
        loadRules();
        showStatus('Success', ruleId ? 'Rule updated successfully.' : 'Rule created successfully.', 'success');
      } catch (e) {
        showStatus('Error', 'Failed to save rule: ' + e.message, 'error');
      }
      btn.disabled = false;
      btn.innerHTML = originalText;
    });

    async function deleteRule(id) {
      if (!confirm('Are you sure you want to delete this rule?')) return;
      try {
        await api(`/api/rules/${id}`, { method: 'DELETE' });
        showStatus('Success', 'Rule deleted successfully.', 'success');
        loadRules();
      } catch (e) {
        showStatus('Error', 'Failed to delete rule: ' + e.message, 'error');
      }
    }

    async function populateRulesFromJSON() {
      if (!confirm('This will import rules from the windows_error_events.json file. Existing rules will not be affected. Continue?')) return;
      try {
        const result = await api('/api/populate-rules', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ overwrite: false }) });
        showStatus('Success', `Successfully imported ${result.rules_created} rules from JSON file.`, 'success');
        loadRules();
      } catch (e) {
        showStatus('Error', 'Failed to import rules: ' + e.message, 'error');
      }
    }

    // History
    async function loadHistory() {
      try {
        const rows = await api('/api/history');
        const tbody = document.querySelector('#history-table tbody');
        tbody.innerHTML = '';
        if (rows.length === 0) {
          tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4">No remediation history yet. Run a rule or test a rule to see results here.</td></tr>';
          return;
        }
        for (const h of rows) {
          const tr = document.createElement('tr');
          const rawOutput = (h.output || '').trim();
          const outputPreview = rawOutput.substring(0, 120);
          const safeOutput = rawOutput.replace(/"/g, '&quot;').replace(/</g, '&lt;');
          tr.innerHTML = `
        <td><span class="badge bg-primary">${h.id}</span></td>
        <td><code>${h.event_id != null ? h.event_id : ('Row ' + h.event_row_id)}</code></td>
        <td><strong>${h.rule_name || ('Rule #' + h.rule_id)}</strong></td>
        <td>${getStatusBadge(h.status)}</td>
        <td title="${safeOutput}" class="small"><code>${outputPreview || '<em class=\'text-muted\'>No output</em>'}</code></td>
        <td><small class="text-muted">${h.event_timestamp ? new Date(h.event_timestamp).toLocaleString() : 'N/A'}</small></td>
        <td><small class="text-muted">${h.timestamp ? new Date(h.timestamp).toLocaleString() : 'N/A'}</small></td>
      `;
          tbody.appendChild(tr);
        }
      } catch (e) {
        console.error('Failed to load history:', e);
      }
    }

    // Dashboard Functions
    let severityChart = null;
    let categoryChart = null;

    async function loadDashboard() {
      try {
        const [filteredEvents, rules, requests, history] = await Promise.all([
          api('/api/filtered-events'),
          api('/api/rules'),
          api('/api/requests'),
          api('/api/history')
        ]);

        // Update statistics
        document.getElementById('stat-total-events').textContent = filteredEvents.length;
        document.getElementById('stat-total-rules').textContent = rules.length;
        document.getElementById('stat-pending-approvals').textContent = requests.filter(r => r.status === 'pending').length;
        document.getElementById('stat-total-remediations').textContent = history.length;

        // Update charts
        updateSeverityChart(filteredEvents);
        updateCategoryChart(filteredEvents);
        updateRecentEvents(filteredEvents.slice(0, 5));
        updateRecentRemediations(history.slice(0, 5));

        // Load intelligence summary
        loadIntelligenceSummary();
      } catch (e) {
        console.error('Failed to load dashboard:', e);
      }
    }

    async function loadIntelligenceSummary() {
      try {
        const s = await api('/api/intelligence/summary');
        document.getElementById('intel-total-events').textContent    = s.total_events ?? '—';
        document.getElementById('intel-suppressed').textContent       = s.total_suppressed ?? '—';
        document.getElementById('intel-avg-confidence').textContent   = s.avg_confidence ? s.avg_confidence + '/100' : '—';
        document.getElementById('intel-cooldown-rules').textContent   = s.rules_with_cooldown ?? '—';
      } catch (e) {
        console.error('Intelligence summary failed:', e);
      }
    }

    function updateSeverityChart(events) {
      const severityCounts = {};
      events.forEach(e => {
        const sev = e.severity || 'Unknown';
        severityCounts[sev] = (severityCounts[sev] || 0) + 1;
      });

      const ctx = document.getElementById('severityChart');
      if (severityChart) severityChart.destroy();

      severityChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: Object.keys(severityCounts),
          datasets: [{
            data: Object.values(severityCounts),
            backgroundColor: [
              '#dc3545', // Critical - red
              '#ffc107', // High - yellow
              '#0dcaf0', // Medium - cyan
              '#6c757d', // Low - gray
              '#f8f9fa'  // Info - light
            ]
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          animation: false,
          plugins: {
            legend: {
              display: true,
              position: 'right',
              labels: {
                boxWidth: 12,
                font: { size: 11 }
              }
            }
          }
        }
      });
    }

    function updateCategoryChart(events) {
      const categoryCounts = {};
      events.forEach(e => {
        const cat = e.category || 'Unknown';
        categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
      });

      // Get top 10 categories
      const sortedCategories = Object.entries(categoryCounts)
        .sort((a, b) => b[1] - a[1])
        .slice(0, 10);

      // Generate dynamic pastel colors for the bar chart
      const barColors = [
        '#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b',
        '#858796', '#5a5c69', '#fd7e14', '#20c997', '#6f42c1'
      ];

      const ctx = document.getElementById('categoryChart');
      if (categoryChart) categoryChart.destroy();

      categoryChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: sortedCategories.map(c => c[0]),
          datasets: [{
            label: 'Event Count',
            data: sortedCategories.map(c => c[1]),
            backgroundColor: sortedCategories.map((c, i) => barColors[i % barColors.length]),
            borderRadius: 4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          animation: false,
          plugins: {
            legend: {
              display: false
            }
          },
          scales: {
            x: {
              grid: { display: false }
            },
            y: {
              beginAtZero: true,
              ticks: { stepSize: 1 }
            }
          }
        }
      });
    }

    function updateRecentEvents(events) {
      const list = document.getElementById('recent-events-list');
      if (events.length === 0) {
        list.innerHTML = '<div class="list-group-item text-center text-muted">No recent events</div>';
        return;
      }

      list.innerHTML = events.map(e => `
    <div class="list-group-item list-group-item-action">
      <div class="d-flex w-100 justify-content-between align-items-start">
        <div>
          <h6 class="mb-1">Event ${e.event_id} - ${e.source}</h6>
          <p class="mb-1 small text-muted">${e.description || e.message || 'No description'}</p>
        </div>
        ${getSeverityBadge(e.severity)}
      </div>
      <small class="text-muted">${new Date(e.timestamp).toLocaleString()}</small>
    </div>
  `).join('');
    }

    function updateRecentRemediations(history) {
      const list = document.getElementById('recent-remediations-list');
      if (history.length === 0) {
        list.innerHTML = '<div class="list-group-item text-center text-muted">No recent remediations</div>';
        return;
      }

      list.innerHTML = history.map(h => `
    <div class="list-group-item">
      <div class="d-flex w-100 justify-content-between align-items-start">
        <div>
          <h6 class="mb-1">${h.rule_name || 'Rule ' + h.rule_id}</h6>
          <p class="mb-1 small text-muted">Event ${h.event_id || h.event_row_id}</p>
        </div>
        ${getStatusBadge(h.status)}
      </div>
      <div class="small text-muted mt-2">
        <div>Event time: ${h.event_timestamp ? new Date(h.event_timestamp).toLocaleString() : 'N/A'}</div>
        <div>Remediated: ${h.timestamp ? new Date(h.timestamp).toLocaleString() : 'N/A'}</div>
      </div>
    </div>
  `).join('');
    }

    // Event Definitions/Catalog Functions
    let allDefinitions = [];
    let filteredDefinitions = [];

    async function loadEventDefinitions() {
      // Guard: elements only exist if the Event Catalog tab is present in the DOM
      const countEl = document.getElementById('definitions-count');
      if (!countEl) return;
      try {
        allDefinitions = await api('/api/event-definitions');
        filteredDefinitions = [...allDefinitions];
        countEl.textContent = allDefinitions.length;
        const categories = [...new Set(allDefinitions.map(d => d.category))].sort();
        const categoryFilter = document.getElementById('filter-category');
        if (categoryFilter) {
          categoryFilter.innerHTML = '<option value="">All Categories</option>' +
            categories.map(c => `<option value="${c}">${c}</option>`).join('');
        }
        displayEventDefinitions(filteredDefinitions);
      } catch (e) {
        console.error('Failed to load event definitions:', e);
      }
    }

    function displayEventDefinitions(definitions) {
      const tbody = document.querySelector('#definitions-table tbody');
      if (definitions.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4">No event definitions found</td></tr>';
        return;
      }

      tbody.innerHTML = definitions.map(d => {
        const descPreview = d.description && d.description.length > 80 ? d.description.substring(0, 80) + '...' : d.description;
        return `
      <tr>
        <td><code class="fw-bold">${d.event_id}</code></td>
        <td><small>${d.event_source}</small></td>
        <td>${getCategoryBadge(d.category)}</td>
        <td>${getSeverityBadge(d.severity)}</td>
        <td title="${d.description}" class="small">${descPreview}</td>
        <td class="text-center">
          ${d.auto_remediate_candidate ?
            '<span class="badge bg-success"><i class="fas fa-check me-1"></i>Yes</span>' :
            '<span class="badge bg-secondary">No</span>'}
        </td>
        <td class="text-center">
          <button class="btn btn-sm btn-outline-primary" onclick='createRuleFromDefinition(${JSON.stringify(d)})' title="Create rule from this definition">
            <i class="fas fa-plus me-1"></i>Create Rule
          </button>
        </td>
      </tr>
    `;
      }).join('');
    }

    function filterEventDefinitions() {
      const searchTerm = document.getElementById('definitions-search').value.toLowerCase();
      const severityFilter = document.getElementById('filter-severity').value;
      const categoryFilter = document.getElementById('filter-category').value;
      const autoRemediateFilter = document.getElementById('filter-auto-remediate').value;

      filteredDefinitions = allDefinitions.filter(d => {
        // Search filter
        const matchesSearch = !searchTerm ||
          d.event_id.toString().includes(searchTerm) ||
          d.event_source.toLowerCase().includes(searchTerm) ||
          d.category.toLowerCase().includes(searchTerm) ||
          d.severity.toLowerCase().includes(searchTerm) ||
          (d.description && d.description.toLowerCase().includes(searchTerm));

        // Severity filter
        const matchesSeverity = !severityFilter || d.severity === severityFilter;

        // Category filter
        const matchesCategory = !categoryFilter || d.category === categoryFilter;

        // Auto-remediate filter
        const matchesAutoRemediate = !autoRemediateFilter ||
          (autoRemediateFilter === 'true' && d.auto_remediate_candidate) ||
          (autoRemediateFilter === 'false' && !d.auto_remediate_candidate);

        return matchesSearch && matchesSeverity && matchesCategory && matchesAutoRemediate;
      });

      displayEventDefinitions(filteredDefinitions);
    }

    function clearDefinitionsFilters() {
      document.getElementById('definitions-search').value = '';
      document.getElementById('filter-severity').value = '';
      document.getElementById('filter-category').value = '';
      document.getElementById('filter-auto-remediate').value = '';
      filterEventDefinitions();
    }

    function sleep(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }

    function classifyTimelineClass(status) {
      if (status === 'completed' || status === 'success') return 'completed';
      if (status === 'warning' || status === 'suppressed') return 'warning';
      if (status === 'failed' || status === 'error') return 'failed';
      return 'simulated';
    }

    function renderTimelineSteps(steps, uptoIndex = null) {
      const timeline = document.getElementById('sim-timeline');
      if (!timeline) return;
      const list = (steps || []).filter((_, idx) => uptoIndex === null || idx <= uptoIndex);
      const html = list.map(step => {
        const cls = classifyTimelineClass(step.status);
        return `
          <div class="timeline-item ${cls}">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <div class="timeline-title">${step.title}</div>
              <div class="timeline-detail">${step.detail}</div>
            </div>
          </div>
        `;
      }).join('');
      timeline.innerHTML = html || '<div class="text-muted">No timeline details provided.</div>';
    }

    async function playbackTimeline(steps, speedMultiplier, statusBox, simContext) {
      const baseDelay = Math.max(180, Math.round(420 / Math.max(0.25, speedMultiplier || 1)));
      for (let i = 0; i < steps.length; i++) {
        const step = steps[i];
        renderTimelineSteps(steps, i);

        if (statusBox) {
          const icon = classifyTimelineClass(step.status) === 'failed' ? 'fa-exclamation-circle' : 'fa-radar';
          statusBox.className = 'alert alert-warning mb-0 small';
          statusBox.innerHTML = `<i class="fas ${icon} me-2"></i>${step.title}`;
        }

        // Keep the Windows simulator synchronized with current phase.
        if (step.phase === 'detect' || step.phase === 'triage') {
          setWindowsSimState('crashed', simContext);
        }
        if (step.phase === 'remediate' || step.phase === 'retry' || step.phase === 'verify') {
          setWindowsSimState('remediating', simContext);
        }
        if (step.phase === 'close') {
          setWindowsSimState('recovered', simContext);
        }
        if (step.phase === 'escalate') {
          setWindowsSimState('failed', simContext);
        }

        let delay = baseDelay;
        if (step.phase === 'verify') delay += 120;
        if (step.phase === 'retry') delay += 150;
        await sleep(delay);
      }
    }

    function setWindowsSimState(state, opts = {}) {
      const stateBadge = document.getElementById('sim-app-state-badge');
      const title = document.getElementById('sim-app-message-title');
      const body = document.getElementById('sim-app-message-body');
      const crashDialog = document.getElementById('windowsCrashDialog');
      const crashAppLabel = document.getElementById('sim-crash-app-label');
      const crashDetail = document.getElementById('sim-crash-detail');
      const fixStatus = document.getElementById('sim-fix-status');
      const fixProgress = document.getElementById('sim-fix-progress');
      const appTitle = document.getElementById('sim-app-title');

      if (!stateBadge || !title || !body || !crashDialog || !fixStatus || !fixProgress || !appTitle) return;

      const appName = opts.appName || 'DemoCrashApp';
      const moduleName = opts.moduleName || 'ntdll.dll';
      const exceptionCode = opts.exceptionCode || '0xc0000005';

      appTitle.textContent = `${appName}.exe`;
      crashAppLabel.textContent = `${appName}.exe`;
      crashDetail.textContent = `Faulting module: ${moduleName} | Exception: ${exceptionCode}`;

      if (state === 'idle') {
        stateBadge.textContent = 'Running Normally';
        stateBadge.className = 'sim-app-state state-ok';
        title.textContent = 'Application Running';
        body.textContent = 'The application is stable and responding.';
        crashDialog.style.display = 'none';
        fixStatus.textContent = 'Awaiting remediation...';
        fixProgress.style.width = '0%';
        return;
      }

      if (state === 'crashed') {
        stateBadge.textContent = 'Crash Detected';
        stateBadge.className = 'sim-app-state state-crash';
        title.textContent = 'Unhandled Exception';
        body.textContent = `Crash signature generated for ${appName}.exe.`;
        crashDialog.style.display = 'block';
        fixStatus.textContent = 'Crash captured. Matching remediation rule...';
        fixProgress.style.width = '18%';
        return;
      }

      if (state === 'remediating') {
        stateBadge.textContent = 'Auto-Remediating';
        stateBadge.className = 'sim-app-state state-fixing';
        title.textContent = 'Recovery In Progress';
        body.textContent = 'Executing Error1000_ApplicationCrash.ps1 via remediation engine.';
        crashDialog.style.display = 'block';
        fixStatus.textContent = 'Running fix script...';
        fixProgress.style.width = '72%';
        return;
      }

      if (state === 'recovered') {
        stateBadge.textContent = 'Recovered';
        stateBadge.className = 'sim-app-state state-ok';
        title.textContent = 'Application Restored';
        body.textContent = `${appName}.exe recovered after script execution.`;
        crashDialog.style.display = 'block';
        fixStatus.textContent = 'Remediation succeeded. Service restored.';
        fixProgress.style.width = '100%';
        return;
      }

      if (state === 'failed') {
        stateBadge.textContent = 'Recovery Failed';
        stateBadge.className = 'sim-app-state state-crash';
        title.textContent = 'Manual Intervention Required';
        body.textContent = 'Remediation script finished with errors.';
        crashDialog.style.display = 'block';
        fixStatus.textContent = 'Remediation failed. Review output below.';
        fixProgress.style.width = '100%';
      }
    }

    async function runError1000Simulation() {
      // Check for saved preferences
      let pref = await checkSimulationPreference('crash');
      
      // Show dialog if:
      // 1. No preference exists yet, OR
      // 2. Preference exists but auto_remediate is OFF (ask every time)
      if (!pref || !pref.auto_remediate) {
        pref = await showSimulationPreferencesModal('crash');
        if (!pref) return; // User skipped
      }

      const btn = document.getElementById('sim-run-btn');
      const statusBox = document.getElementById('sim-status-box');
      const countInput = document.getElementById('simulation-count');
      const appNameInput = document.getElementById('simulation-app-name');
      const moduleInput = document.getElementById('simulation-module');
      const exceptionInput = document.getElementById('simulation-exception');
      const profileInput = document.getElementById('simulation-profile');
      const retryInput = document.getElementById('simulation-retry');
      const verifyInput = document.getElementById('simulation-verify');
      const livePlaybackInput = document.getElementById('simulation-live-playback');
      const playbackSpeedInput = document.getElementById('simulation-playback-speed');
      const timeline = document.getElementById('sim-timeline');
      const output = document.getElementById('sim-terminal-output');
      const summaryBadge = document.getElementById('sim-summary-badge');
      const resultCards = document.getElementById('sim-result-cards');
      const appName = (appNameInput.value || 'DemoCrashApp').trim();
      const moduleName = (moduleInput.value || 'ntdll.dll').trim();
      const exceptionCode = (exceptionInput.value || '0xc0000005').trim();
      const profile = (profileInput.value || 'degraded').trim();
      const retryOnFailure = !!retryInput.checked;
      const verifyRecovery = !!verifyInput.checked;
      const livePlayback = !!(livePlaybackInput && livePlaybackInput.checked);
      const playbackSpeed = parseFloat(playbackSpeedInput?.value || '1') || 1;

      const metricResolved = document.getElementById('sim-metric-resolved');
      const metricEscalated = document.getElementById('sim-metric-escalated');
      const metricRetries = document.getElementById('sim-metric-retries');
      const metricMttr = document.getElementById('sim-metric-mttr');

      const eventCount = Math.max(1, Math.min(5, parseInt(countInput.value || '1', 10)));
      countInput.value = eventCount;

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Running...';
      statusBox.className = 'alert alert-warning mb-0 small';
      statusBox.innerHTML = `<i class="fas fa-hourglass-half me-2"></i>Running ${profile} incident simulation with remediation pipeline...`;
      timeline.innerHTML = '<div class="text-muted">Generating timeline...</div>';
      output.textContent = 'Running simulation...';
      resultCards.innerHTML = '<div class="text-muted">Collecting event and rule results...</div>';
      if (metricResolved) metricResolved.textContent = '0';
      if (metricEscalated) metricEscalated.textContent = '0';
      if (metricRetries) metricRetries.textContent = '0';
      if (metricMttr) metricMttr.textContent = '0';
      setWindowsSimState('idle', { appName, moduleName, exceptionCode });
      await sleep(350);
      setWindowsSimState('crashed', { appName, moduleName, exceptionCode });
      await sleep(450);
      setWindowsSimState('remediating', { appName, moduleName, exceptionCode });

      try {
        const result = await api('/api/simulations/error1000/auto-fix', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            count: eventCount,
            app_name: appName,
            module_name: moduleName,
            exception_code: exceptionCode,
            profile: profile,
            retry_on_failure: retryOnFailure,
            verify_recovery: verifyRecovery
          })
        });

        document.getElementById('sim-fix-command').textContent = result.fix_script || 'sfc /scannow';
        const timelineSteps = result.timeline || [];
        if (livePlayback) {
          timeline.innerHTML = '<div class="text-muted">Streaming timeline playback...</div>';
          await playbackTimeline(timelineSteps, playbackSpeed, statusBox, { appName, moduleName, exceptionCode });
        } else {
          renderTimelineSteps(timelineSteps);
        }
        output.textContent = result.latest_output || 'No script output generated.';

        const events = result.events || [];
        if (events.length === 0) {
          resultCards.innerHTML = '<div class="text-muted">No events generated.</div>';
        } else {
          resultCards.innerHTML = events.map((ev, idx) => {
            const remediation = (ev.remediations && ev.remediations[ev.remediations.length - 1]) || null;
            const remStatus = remediation
              ? getStatusBadge(remediation.verification_passed ? 'success' : (remediation.status || 'unknown'))
              : '<span class="badge bg-secondary">No Auto-Run</span>';
            const attempts = (ev.remediations || []).length;
            const resolutionText = ev.resolved
              ? '<span class="badge bg-success">Resolved</span>'
              : '<span class="badge bg-danger">Escalated</span>';
            return `
              <div class="p-3" style="border:1px solid var(--glass-border);border-radius:10px;background:rgba(255,255,255,0.02)">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <strong>Crash Event ${idx + 1} (Row ${ev.event_row_id})</strong>
                  ${remStatus}
                </div>
                <div class="small text-muted mb-2">${ev.message || ''}</div>
                <div class="small">Matched Rules: ${(ev.matches || []).length} | Attempts: ${attempts} | ${resolutionText}</div>
              </div>
            `;
          }).join('');
        }

        const summary = result.summary || {};
        summaryBadge.textContent = `${summary.events_created || 0} crashes | ${summary.incident_resolved || 0} resolved | ${summary.incident_unresolved || 0} escalated`;

        if (metricResolved) metricResolved.textContent = `${summary.incident_resolved || 0}`;
        if (metricEscalated) metricEscalated.textContent = `${summary.incident_unresolved || 0}`;
        if (metricRetries) metricRetries.textContent = `${summary.retries_performed || 0}`;
        if (metricMttr) metricMttr.textContent = `${summary.mean_time_to_recover_seconds || 0}`;

        if ((summary.incident_unresolved || 0) > 0) {
          setWindowsSimState('failed', { appName, moduleName, exceptionCode });
        } else {
          setWindowsSimState('recovered', { appName, moduleName, exceptionCode });
        }

        statusBox.className = 'alert alert-success mb-0 small';
        statusBox.innerHTML = '<i class="fas fa-check-circle me-2"></i>Crash simulation complete and auto-remediation pipeline executed.';

        loadHistory();
        loadDashboard();
        loadFilteredEvents();
      } catch (e) {
        statusBox.className = 'alert alert-danger mb-0 small';
        statusBox.innerHTML = `<i class="fas fa-exclamation-circle me-2"></i>Simulation failed: ${e.message}`;
        summaryBadge.textContent = 'Simulation failed';
        timeline.innerHTML = '<div class="text-danger">Unable to generate simulation timeline.</div>';
        output.textContent = 'Simulation failed.';
        resultCards.innerHTML = '<div class="text-danger">No result cards available.</div>';
        setWindowsSimState('failed', { appName, moduleName, exceptionCode });
      }

      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-play me-1"></i>Run Simulation';
    }

    function switchSimulation(type) {
      // Update dropdown selection
      const selector = document.getElementById('simulation-type-selector');
      if (selector) {
        selector.value = type;
      }

      const allLabCards = ['crashLabCard','diskLabCard','eventlogLabCard','auditeventsLabCard','highcpuLabCard','servicecrashLabCard'];
      const allSimCards = ['crashSimCard','diskSimCard','eventlogSimCard','auditeventsSimCard'];
      allLabCards.forEach(id => { const el = document.getElementById(id); if(el) el.style.display='none'; });
      allSimCards.forEach(id => { const el = document.getElementById(id); if(el) el.style.display='none'; });

      if (type === 'crash') {
        document.getElementById('crashLabCard').style.display = '';
        document.getElementById('crashSimCard').style.display = '';
      } else if (type === 'diskspace') {
        document.getElementById('diskLabCard').style.display = '';
        document.getElementById('diskSimCard').style.display = '';
      } else if (type === 'eventlog') {
        document.getElementById('eventlogLabCard').style.display = '';
        document.getElementById('eventlogSimCard').style.display = '';
      } else if (type === 'auditevents') {
        document.getElementById('auditeventsLabCard').style.display = '';
        document.getElementById('auditeventsSimCard').style.display = '';
      } else if (type === 'highcpu') {
        document.getElementById('highcpuLabCard').style.display = '';
      } else if (type === 'servicecrash') {
        document.getElementById('servicecrashLabCard').style.display = '';
      }
    }

    // Set crash lab as default
    switchSimulation('crash');

    async function runLowDiskSpaceSimulation() {
      // Check for saved preferences
      let pref = await checkSimulationPreference('diskspace');
      
      // Show dialog if:
      // 1. No preference exists yet, OR
      // 2. Preference exists but auto_remediate is OFF (ask every time)
      if (!pref || !pref.auto_remediate) {
        pref = await showSimulationPreferencesModal('diskspace');
        if (!pref) return; // User skipped
      }

      const btn = document.getElementById('disk-sim-run-btn');
      const statusBox = document.getElementById('disk-sim-status-box');
      const countInput = document.getElementById('disk-simulation-count');
      const profileInput = document.getElementById('disk-simulation-profile');
      const retryInput = document.getElementById('disk-simulation-retry');
      const verifyInput = document.getElementById('disk-simulation-verify');
      const livePlaybackInput = document.getElementById('disk-simulation-live-playback');
      const playbackSpeedInput = document.getElementById('disk-simulation-playback-speed');
      const timeline = document.getElementById('sim-timeline');
      const output = document.getElementById('sim-terminal-output');
      const summaryBadge = document.getElementById('sim-summary-badge');
      const resultCards = document.getElementById('sim-result-cards');

      const profile = (profileInput.value || 'degraded').trim();
      const retryOnFailure = !!retryInput.checked;
      const verifyRecovery = !!verifyInput.checked;
      const livePlayback = !!(livePlaybackInput && livePlaybackInput.checked);
      const playbackSpeed = parseFloat(playbackSpeedInput?.value || '1') || 1;

      const metricResolved = document.getElementById('sim-metric-resolved');
      const metricEscalated = document.getElementById('sim-metric-escalated');
      const metricRetries = document.getElementById('sim-metric-retries');
      const metricMttr = document.getElementById('sim-metric-mttr');

      const eventCount = Math.max(1, Math.min(5, parseInt(countInput.value || '1', 10)));
      countInput.value = eventCount;

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Running...';
      statusBox.className = 'alert alert-warning mb-0 small';
      statusBox.innerHTML = `<i class="fas fa-hourglass-half me-2"></i>Running ${profile} disk space simulation with remediation pipeline...`;
      timeline.innerHTML = '<div class="text-muted">Generating timeline...</div>';
      output.textContent = 'Running simulation...';
      resultCards.innerHTML = '<div class="text-muted">Collecting event and cleanup results...</div>';
      if (metricResolved) metricResolved.textContent = '0';
      if (metricEscalated) metricEscalated.textContent = '0';
      if (metricRetries) metricRetries.textContent = '0';
      if (metricMttr) metricMttr.textContent = '0';
      
      // Update disk simulator display
      await updateDiskSimulatorState('checking');
      await sleep(350);

      try {
        const result = await api('/api/simulations/lowdiskspace/auto-fix', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            count: eventCount,
            profile: profile,
            retry_on_failure: retryOnFailure,
            verify_recovery: verifyRecovery
          })
        });

        document.getElementById('disk-sim-fix-command').textContent = result.cleanup_script || 'Disk cleanup';
        const timelineSteps = result.timeline || [];
        if (livePlayback) {
          timeline.innerHTML = '<div class="text-muted">Streaming timeline playback...</div>';
          await playbackTimeline(timelineSteps, playbackSpeed, statusBox);
        } else {
          renderTimelineSteps(timelineSteps);
        }
        output.textContent = result.latest_output || 'No script output generated.';

        const events = result.events || [];
        if (events.length === 0) {
          resultCards.innerHTML = '<div class="text-muted">No events generated.</div>';
        } else {
          resultCards.innerHTML = events.map((ev, idx) => {
            const remediation = (ev.remediations && ev.remediations[ev.remediations.length - 1]) || null;
            const remStatus = remediation
              ? getStatusBadge(remediation.verification_passed ? 'success' : (remediation.status || 'unknown'))
              : '<span class="badge bg-secondary">No Auto-Run</span>';
            const attempts = (ev.remediations || []).length;
            const resolutionText = ev.resolved
              ? '<span class="badge bg-success">Cleaned</span>'
              : '<span class="badge bg-danger">Escalated</span>';
            return `
              <div class="p-3" style="border:1px solid var(--glass-border);border-radius:10px;background:rgba(255,255,255,0.02)">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <strong>Disk Event ${idx + 1} - ${ev.drive} (Row ${ev.event_row_id})</strong>
                  ${remStatus}
                </div>
                <div class="small text-muted mb-2">${ev.message || ''}</div>
                <div class="small">Matched Rules: ${(ev.matches || []).length} | Attempts: ${attempts} | ${resolutionText}</div>
              </div>
            `;
          }).join('');
        }

        const summary = result.summary || {};
        summaryBadge.textContent = `${summary.events_created || 0} disk alerts | ${summary.incident_resolved || 0} cleaned | ${summary.incident_unresolved || 0} failed`;

        if (metricResolved) metricResolved.textContent = `${summary.incident_resolved || 0}`;
        if (metricEscalated) metricEscalated.textContent = `${summary.incident_unresolved || 0}`;
        if (metricRetries) metricRetries.textContent = `${summary.retries_performed || 0}`;
        if (metricMttr) metricMttr.textContent = `${summary.mean_time_to_recover_seconds || 0}`;

        if ((summary.incident_unresolved || 0) > 0) {
          await updateDiskSimulatorState('failed');
        } else {
          await updateDiskSimulatorState('cleaned');
        }

        statusBox.className = 'alert alert-success mb-0 small';
        statusBox.innerHTML = '<i class="fas fa-check-circle me-2"></i>Disk space simulation complete and auto-remediation pipeline executed.';

        loadHistory();
        loadDashboard();
        loadFilteredEvents();
      } catch (e) {
        statusBox.className = 'alert alert-danger mb-0 small';
        statusBox.innerHTML = `<i class="fas fa-exclamation-circle me-2"></i>Simulation failed: ${e.message}`;
        summaryBadge.textContent = 'Simulation failed';
        timeline.innerHTML = '<div class="text-danger">Unable to generate simulation timeline.</div>';
        output.textContent = 'Simulation failed.';
        resultCards.innerHTML = '<div class="text-danger">No result cards available.</div>';
        await updateDiskSimulatorState('error');
      }

      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-play me-1"></i>Run Simulation';
    }

    async function updateDiskSimulatorState(state) {
      const drivesDisplay = document.getElementById('disk-sim-drives-display');
      const statusDetail = document.getElementById('disk-sim-status-detail');
      
      if (state === 'checking') {
        statusDetail.textContent = 'Scanning drives for low disk space...';
      } else if (state === 'cleaned') {
        drivesDisplay.innerHTML = `
          <div style="padding:10px;background:rgba(76,175,80,0.1);border-radius:8px;margin-bottom:10px;border:1px solid rgba(76,175,80,0.3);">
            <div class="d-flex justify-content-between align-items-center">
              <span>C: Drive</span>
              <span class="badge bg-success">Cleaned</span>
            </div>
            <div class="small text-muted mt-1">12.5 GB free of 500 GB (2.5%)</div>
            <div style="height:8px;background:rgba(255,255,255,0.1);border-radius:4px;margin-top:8px;overflow:hidden;">
              <div style="height:100%;width:15%;background:#4caf50;border-radius:4px;"></div>
            </div>
          </div>
        `;
        statusDetail.textContent = 'Cleanup completed successfully. Drive space freed.';
      } else if (state === 'failed') {
        statusDetail.textContent = 'Cleanup failed - manual intervention required.';
      } else if (state === 'error') {
        statusDetail.textContent = 'Simulation error occurred.';
      }
    }

    async function runEventLogSimulation() {
      // Check for saved preferences
      let pref = await checkSimulationPreference('eventlog');
      
      // Show dialog if:
      // 1. No preference exists yet, OR
      // 2. Preference exists but auto_remediate is OFF (ask every time)
      if (!pref || !pref.auto_remediate) {
        pref = await showSimulationPreferencesModal('eventlog');
        if (!pref) return; // User skipped
      }

      const btn = document.getElementById('eventlog-sim-run-btn');
      const statusBox = document.getElementById('eventlog-sim-status-box');
      const countInput = document.getElementById('eventlog-simulation-count');
      const profileInput = document.getElementById('eventlog-simulation-profile');
      const retryInput = document.getElementById('eventlog-simulation-retry');
      const verifyInput = document.getElementById('eventlog-simulation-verify');
      const livePlaybackInput = document.getElementById('eventlog-simulation-live-playback');
      const playbackSpeedInput = document.getElementById('eventlog-simulation-playback-speed');
      const timeline = document.getElementById('sim-timeline');
      const output = document.getElementById('sim-terminal-output');
      const summaryBadge = document.getElementById('sim-summary-badge');
      const resultCards = document.getElementById('sim-result-cards');

      const profile = (profileInput.value || 'degraded').trim();
      const retryOnFailure = !!retryInput.checked;
      const verifyRecovery = !!verifyInput.checked;
      const livePlayback = !!(livePlaybackInput && livePlaybackInput.checked);
      const playbackSpeed = parseFloat(playbackSpeedInput?.value || '1') || 1;

      const metricResolved = document.getElementById('sim-metric-resolved');
      const metricEscalated = document.getElementById('sim-metric-escalated');
      const metricRetries = document.getElementById('sim-metric-retries');
      const metricMttr = document.getElementById('sim-metric-mttr');

      const eventCount = Math.max(1, Math.min(3, parseInt(countInput.value || '1', 10)));
      countInput.value = eventCount;

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Running...';
      statusBox.className = 'alert alert-warning mb-0 small';
      statusBox.innerHTML = `<i class="fas fa-hourglass-half me-2"></i>Running ${profile} event log recovery simulation with remediation pipeline...`;
      timeline.innerHTML = '<div class="text-muted">Generating timeline...</div>';
      output.textContent = 'Running simulation...';
      resultCards.innerHTML = '<div class="text-muted">Collecting service recovery results...</div>';
      if (metricResolved) metricResolved.textContent = '0';
      if (metricEscalated) metricEscalated.textContent = '0';
      if (metricRetries) metricRetries.textContent = '0';
      if (metricMttr) metricMttr.textContent = '0';
      
      // Update event log simulator display
      await updateEventLogSimulatorState('detecting');
      await sleep(350);

      try {
        const result = await api('/api/simulations/eventlog/auto-fix', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            count: eventCount,
            profile: profile,
            retry_on_failure: retryOnFailure,
            verify_recovery: verifyRecovery
          })
        });

        document.getElementById('eventlog-sim-fix-command').textContent = result.fix_script || 'Service recovery';
        const timelineSteps = result.timeline || [];
        if (livePlayback) {
          timeline.innerHTML = '<div class="text-muted">Streaming timeline playback...</div>';
          await playbackTimeline(timelineSteps, playbackSpeed, statusBox);
        } else {
          renderTimelineSteps(timelineSteps);
        }
        output.textContent = result.latest_output || 'No script output generated.';

        const events = result.events || [];
        if (events.length === 0) {
          resultCards.innerHTML = '<div class="text-muted">No events generated.</div>';
        } else {
          resultCards.innerHTML = events.map((ev, idx) => {
            const remediation = (ev.remediations && ev.remediations[ev.remediations.length - 1]) || null;
            const remStatus = remediation
              ? getStatusBadge(remediation.verification_passed ? 'success' : (remediation.status || 'unknown'))
              : '<span class="badge bg-secondary">No Auto-Run</span>';
            const attempts = (ev.remediations || []).length;
            const resolutionText = ev.resolved
              ? '<span class="badge bg-success">Recovered</span>'
              : '<span class="badge bg-danger">Failed</span>';
            return `
              <div class="p-3" style="border:1px solid var(--glass-border);border-radius:10px;background:rgba(255,255,255,0.02)">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <strong>Event Log Event ${idx + 1} (Row ${ev.event_row_id})</strong>
                  ${remStatus}
                </div>
                <div class="small text-muted mb-2">${ev.message || ''}</div>
                <div class="small">Matched Rules: ${(ev.matches || []).length} | Attempts: ${attempts} | ${resolutionText}</div>
              </div>
            `;
          }).join('');
        }

        const summary = result.summary || {};
        summaryBadge.textContent = `${summary.events_created || 0} shutdowns | ${summary.incident_resolved || 0} recovered | ${summary.incident_unresolved || 0} failed`;

        if (metricResolved) metricResolved.textContent = `${summary.incident_resolved || 0}`;
        if (metricEscalated) metricEscalated.textContent = `${summary.incident_unresolved || 0}`;
        if (metricRetries) metricRetries.textContent = `${summary.retries_performed || 0}`;
        if (metricMttr) metricMttr.textContent = `${summary.mean_time_to_recover_seconds || 0}`;

        if ((summary.incident_unresolved || 0) > 0) {
          await updateEventLogSimulatorState('failed');
        } else {
          await updateEventLogSimulatorState('recovered');
        }

        statusBox.className = 'alert alert-success mb-0 small';
        statusBox.innerHTML = '<i class="fas fa-check-circle me-2"></i>Event Log recovery simulation complete and auto-remediation pipeline executed.';

        loadHistory();
        loadDashboard();
        loadFilteredEvents();
      } catch (e) {
        statusBox.className = 'alert alert-danger mb-0 small';
        statusBox.innerHTML = `<i class="fas fa-exclamation-circle me-2"></i>Simulation failed: ${e.message}`;
        summaryBadge.textContent = 'Simulation failed';
        timeline.innerHTML = '<div class="text-danger">Unable to generate simulation timeline.</div>';
        output.textContent = 'Simulation failed.';
        resultCards.innerHTML = '<div class="text-danger">No result cards available.</div>';
        await updateEventLogSimulatorState('error');
      }

      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-play me-1"></i>Run Simulation';
    }

    async function updateEventLogSimulatorState(state) {
      const statusDisplay = document.getElementById('eventlog-sim-status-display');
      const statusDetail = document.getElementById('eventlog-sim-status-detail');
      
      if (state === 'detecting') {
        statusDetail.textContent = 'Detecting Event Log service status...';
      } else if (state === 'recovered') {
        statusDisplay.innerHTML = `
          <div style="padding:10px;background:rgba(76,175,80,0.1);border-radius:8px;margin-bottom:10px;border:1px solid rgba(76,175,80,0.3);">
            <div class="d-flex justify-content-between align-items-center">
              <span>EventLog Service</span>
              <span class="badge bg-success">Online</span>
            </div>
            <div class="small text-muted mt-1">Status: Running | Startup: Automatic | Last Restart: Just now</div>
            <div style="height:8px;background:rgba(255,255,255,0.1);border-radius:4px;margin-top:8px;overflow:hidden;">
              <div style="height:100%;width:100%;background:#4caf50;border-radius:4px;"></div>
            </div>
          </div>
        `;
        statusDetail.textContent = 'Service recovery successful. Event logging resumed.';
      } else if (state === 'failed') {
        statusDisplay.innerHTML = `
          <div style="padding:10px;background:rgba(220,51,68,0.1);border-radius:8px;margin-bottom:10px;border:1px solid rgba(220,51,68,0.3);">
            <div class="d-flex justify-content-between align-items-center">
              <span>EventLog Service</span>
              <span class="badge bg-danger">Failed</span>
            </div>
            <div class="small text-muted mt-1">Status: Stopped | Startup: Automatic | Last Restart: Failed</div>
            <div style="height:8px;background:rgba(255,255,255,0.1);border-radius:4px;margin-top:8px;overflow:hidden;">
              <div style="height:100%;width:0%;background:#dc3545;border-radius:4px;"></div>
            </div>
          </div>
        `;
        statusDetail.textContent = 'Service recovery failed - manual intervention required.';
      } else if (state === 'error') {
        statusDetail.textContent = 'Simulation error occurred.';
      }
    }

    async function runAuditEventsSimulation() {
      // Check for saved preferences
      let pref = await checkSimulationPreference('auditevents');
      
      // Show dialog if:
      // 1. No preference exists yet, OR
      // 2. Preference exists but auto_remediate is OFF (ask every time)
      if (!pref || !pref.auto_remediate) {
        pref = await showSimulationPreferencesModal('auditevents');
        if (!pref) return; // User skipped
      }

      const btn = document.getElementById('auditevents-sim-run-btn');
      const statusBox = document.getElementById('auditevents-sim-status-box');
      const countInput = document.getElementById('auditevents-simulation-count');
      const profileInput = document.getElementById('auditevents-simulation-profile');
      const retryInput = document.getElementById('auditevents-simulation-retry');
      const verifyInput = document.getElementById('auditevents-simulation-verify');
      const livePlaybackInput = document.getElementById('auditevents-simulation-live-playback');
      const playbackSpeedInput = document.getElementById('auditevents-simulation-playback-speed');
      const timeline = document.getElementById('sim-timeline');
      const output = document.getElementById('sim-terminal-output');
      const summaryBadge = document.getElementById('sim-summary-badge');
      const resultCards = document.getElementById('sim-result-cards');

      const profile = (profileInput.value || 'degraded').trim();
      const retryOnFailure = !!retryInput.checked;
      const verifyRecovery = !!verifyInput.checked;
      const livePlayback = !!(livePlaybackInput && livePlaybackInput.checked);
      const playbackSpeed = parseFloat(playbackSpeedInput?.value || '1') || 1;

      const metricResolved = document.getElementById('sim-metric-resolved');
      const metricEscalated = document.getElementById('sim-metric-escalated');
      const metricRetries = document.getElementById('sim-metric-retries');
      const metricMttr = document.getElementById('sim-metric-mttr');

      const eventCount = Math.max(1, Math.min(3, parseInt(countInput.value || '1', 10)));
      countInput.value = eventCount;

      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Running...';
      statusBox.className = 'alert alert-warning mb-0 small';
      statusBox.innerHTML = `<i class="fas fa-hourglass-half me-2"></i>Running ${profile} audit events recovery simulation with remediation pipeline...`;
      timeline.innerHTML = '<div class="text-muted">Generating timeline...</div>';
      output.textContent = 'Running simulation...';
      resultCards.innerHTML = '<div class="text-muted">Collecting audit log recovery results...</div>';
      if (metricResolved) metricResolved.textContent = '0';
      if (metricEscalated) metricEscalated.textContent = '0';
      if (metricRetries) metricRetries.textContent = '0';
      if (metricMttr) metricMttr.textContent = '0';
      
      // Update audit events simulator display
      await updateAuditEventsSimulatorState('detecting');
      await sleep(350);

      try {
        const result = await api('/api/simulations/auditevents/auto-fix', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            count: eventCount,
            profile: profile,
            retry_on_failure: retryOnFailure,
            verify_recovery: verifyRecovery
          })
        });

        document.getElementById('auditevents-sim-fix-command').textContent = result.fix_script || 'Expand log size, configure audit policy';
        const timelineSteps = result.timeline || [];
        if (livePlayback) {
          timeline.innerHTML = '<div class="text-muted">Streaming timeline playback...</div>';
          await playbackTimeline(timelineSteps, playbackSpeed, statusBox);
        } else {
          renderTimelineSteps(timelineSteps);
        }
        output.textContent = result.latest_output || 'No script output generated.';

        const events = result.events || [];
        if (events.length === 0) {
          resultCards.innerHTML = '<div class="text-muted">No events generated.</div>';
        } else {
          resultCards.innerHTML = events.map((ev, idx) => {
            const remediation = (ev.remediations && ev.remediations[ev.remediations.length - 1]) || null;
            const remStatus = remediation
              ? getStatusBadge(remediation.verification_passed ? 'success' : (remediation.status || 'unknown'))
              : '<span class="badge bg-secondary">No Auto-Run</span>';
            const attempts = (ev.remediations || []).length;
            const resolutionText = ev.resolved
              ? '<span class="badge bg-success">Recovered</span>'
              : '<span class="badge bg-danger">Failed</span>';
            return `
              <div class="p-3" style="border:1px solid var(--glass-border);border-radius:10px;background:rgba(255,255,255,0.02)">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <strong>Audit Event ${idx + 1} (Row ${ev.event_row_id})</strong>
                  ${remStatus}
                </div>
                <div class="small text-muted mb-2">${ev.message || ''}</div>
                <div class="small">Matched Rules: ${(ev.matches || []).length} | Attempts: ${attempts} | ${resolutionText}</div>
              </div>
            `;
          }).join('');
        }

        const summary = result.summary || {};
        summaryBadge.textContent = `${summary.events_created || 0} audit drops | ${summary.incident_resolved || 0} recovered | ${summary.incident_unresolved || 0} failed`;

        if (metricResolved) metricResolved.textContent = `${summary.incident_resolved || 0}`;
        if (metricEscalated) metricEscalated.textContent = `${summary.incident_unresolved || 0}`;
        if (metricRetries) metricRetries.textContent = `${summary.retries_performed || 0}`;
        if (metricMttr) metricMttr.textContent = `${summary.mean_time_to_recover_seconds || 0}`;

        if ((summary.incident_unresolved || 0) > 0) {
          await updateAuditEventsSimulatorState('failed');
        } else {
          await updateAuditEventsSimulatorState('recovered');
        }

        statusBox.className = 'alert alert-success mb-0 small';
        statusBox.innerHTML = '<i class="fas fa-check-circle me-2"></i>Audit log recovery simulation complete and auto-remediation pipeline executed.';

        loadHistory();
        loadDashboard();
        loadFilteredEvents();
      } catch (e) {
        statusBox.className = 'alert alert-danger mb-0 small';
        statusBox.innerHTML = `<i class="fas fa-exclamation-circle me-2"></i>Simulation failed: ${e.message}`;
        summaryBadge.textContent = 'Simulation failed';
        timeline.innerHTML = '<div class="text-danger">Unable to generate simulation timeline.</div>';
        output.textContent = 'Simulation failed.';
        resultCards.innerHTML = '<div class="text-danger">No result cards available.</div>';
        await updateAuditEventsSimulatorState('error');
      }

      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-play me-1"></i>Run Simulation';
    }

    async function updateAuditEventsSimulatorState(state) {
      const statusDisplay = document.getElementById('auditevents-sim-status-display');
      const statusDetail = document.getElementById('auditevents-sim-status-detail');
      
      if (state === 'detecting') {
        statusDetail.textContent = 'Detecting Audit Log buffer status...';
      } else if (state === 'recovered') {
        statusDisplay.innerHTML = `
          <div style="padding:10px;background:rgba(76,175,80,0.1);border-radius:8px;margin-bottom:10px;border:1px solid rgba(76,175,80,0.3);">
            <div class="d-flex justify-content-between align-items-center">
              <span>Security Audit Log</span>
              <span class="badge bg-success">Healthy</span>
            </div>
            <div class="small text-muted mt-1">Capacity: 100 GB | Usage: 35 GB (35%) | Drop Rate: 0%</div>
            <div style="height:8px;background:rgba(255,255,255,0.1);border-radius:4px;margin-top:8px;overflow:hidden;">
              <div style="height:100%;width:35%;background:#4caf50;border-radius:4px;"></div>
            </div>
          </div>
        `;
        statusDetail.textContent = 'Audit log expansion successful. Events are now being logged normally.';
      } else if (state === 'failed') {
        statusDisplay.innerHTML = `
          <div style="padding:10px;background:rgba(220,51,68,0.1);border-radius:8px;margin-bottom:10px;border:1px solid rgba(220,51,68,0.3);">
            <div class="d-flex justify-content-between align-items-center">
              <span>Security Audit Log</span>
              <span class="badge bg-danger">Failed</span>
            </div>
            <div class="small text-muted mt-1">Capacity: 20 MB | Usage: 19.8 MB (99%) | Drop Rate: 45%</div>
            <div style="height:8px;background:rgba(255,255,255,0.1);border-radius:4px;margin-top:8px;overflow:hidden;">
              <div style="height:100%;width:99%;background:#dc3545;border-radius:4px;"></div>
            </div>
          </div>
        `;
        statusDetail.textContent = 'Audit log expansion failed - manual intervention required.';
      } else if (state === 'error') {
        statusDetail.textContent = 'Simulation error occurred.';
      }
    }

    async function createRuleFromDefinition(definition) {
      // Switch to Rules tab
      const rulesTab = document.querySelector('a[href="#rulesTab"]');
      rulesTab.click();

      // Pre-fill the form
      document.getElementById('rule-id').value = '';
      document.getElementById('rule-name').value = `${definition.category} - ${definition.event_source} Event ${definition.event_id}`;
      document.getElementById('rule-event_id').value = definition.event_id;
      document.getElementById('rule-source').value = definition.event_source;
      document.getElementById('rule-message_regex').value = '';
      document.getElementById('rule-auto').checked = false; // Safety: don't auto-enable

      // Scroll to form
      document.getElementById('rule-form').scrollIntoView({ behavior: 'smooth', block: 'center' });

      showStatus('Info', `Rule form pre-filled from event definition. Add a remediation script and save.`, 'info');
    }

    async function createRuleFromEvent(event) {
      // Switch to Rules tab
      const rulesTab = document.querySelector('a[href="#rulesTab"]');
      rulesTab.click();

      // Pre-fill the form
      document.getElementById('rule-id').value = '';
      const ruleName = event.category ?
        `${event.category} - ${event.source} Event ${event.event_id}` :
        `${event.source} Event ${event.event_id}`;
      document.getElementById('rule-name').value = ruleName;
      document.getElementById('rule-event_id').value = event.event_id;
      document.getElementById('rule-source').value = event.source;
      document.getElementById('rule-message_regex').value = '';
      document.getElementById('rule-auto').checked = false; // Safety: don't auto-enable

      // Scroll to form
      document.getElementById('rule-form').scrollIntoView({ behavior: 'smooth', block: 'center' });

      showStatus('Info', `Rule form pre-filled from event. Add a remediation script and save.`, 'info');
    }

    // Add event listeners for filters
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('definitions-search');
      const severityFilter = document.getElementById('filter-severity');
      const categoryFilter = document.getElementById('filter-category');
      const autoRemediateFilter = document.getElementById('filter-auto-remediate');

      if (searchInput) searchInput.addEventListener('input', filterEventDefinitions);
      if (severityFilter) severityFilter.addEventListener('change', filterEventDefinitions);
      if (categoryFilter) categoryFilter.addEventListener('change', filterEventDefinitions);
      if (autoRemediateFilter) autoRemediateFilter.addEventListener('change', filterEventDefinitions);
    });

    async function refreshAll() {
      // Show loading status
      const btn = document.querySelector('button[onclick="refreshAll()"]');
      if (btn) btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Syncing...';
      try {
        // Force an immediate Windows Event Log pull
        await api('/api/monitor/trigger', 'POST');
      } catch (e) {
        console.warn('Manual monitor trigger failed', e);
      }
      
      loadRules();
      loadHistory();
      loadRequests();
      loadDashboard();
      loadFilteredEvents();
      pollMonitorStatus();
      loadManualReviewCount();
      showStatus('Refreshing', 'Windows Event Logs synced and data reloaded.', 'success');
      
      if (btn) btn.innerHTML = '<i class="fas fa-sync me-1"></i>Refresh All';
    }

    // Initial load
    loadDashboard();
    loadRules();
    loadHistory();
    loadRequests();
    loadFilteredEvents();
    pollMonitorStatus();
    loadManualReviewCount();
    setInterval(() => {
      loadRequests();
      loadDashboard();
      loadFilteredEvents();
      loadHistory();
      pollMonitorStatus();
      loadManualReviewCount();
    }, 10000);

    // ═══════════════════════════════════════════════════════════════════
    //  LIVE ALERT POPUP — polling + inject + remediate functions
    // ═══════════════════════════════════════════════════════════════════

    // Tracks which alert is currently shown in the popup
    let _lapEventRowId = null;
    let _lapRuleId     = null;
    let _lapAlertType  = 'highcpu';   // 'highcpu' | 'servicecrash'
    let _lapDismissedIds = new Set(); // alert IDs dismissed this session

    // Runs Simulate_HighCpuAlert.ps1 via the backend and surfaces the popup
    async function injectHighCpuAlert() {
      const btn = document.getElementById('inject-error-btn');
      if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Injecting...'; }
      try {
        const res = await api('/api/simulations/highcpu/inject', { method: 'POST', headers: {'Content-Type':'application/json'}, body: '{}' });
        if (res.status === 'ok') {
          showLiveAlert({
            id:          res.event_row_id,
            event_id:    res.event_id,
            source:      res.source,
            category:    'High CPU Alert',
            severity:    'High',
            message:     res.message,
            description: res.message,
            timestamp:   res.timestamp,
            rule_id:     res.rule_id,
            alert_type:  'highcpu',
            remediated:  false,
          });
        }
      } catch (e) {
        console.error('Inject High CPU failed:', e);
      }
      if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-bolt me-1"></i>Inject Error'; }
    }

    // Called from the Simulation tab ⚡ button
    async function injectHighCpuAlertFromSim() {
      const btn = document.getElementById('highcpu-inject-btn');
      const statusBox = document.getElementById('highcpu-sim-status-box');
      if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Injecting...'; }
      if (statusBox) { statusBox.className = 'alert alert-warning mb-0 small'; statusBox.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Writing to Windows Event Log and registering event...'; }
      try {
        const res = await api('/api/simulations/highcpu/inject', { method: 'POST', headers: {'Content-Type':'application/json'}, body: '{}' });
        if (res.status === 'ok') {
          if (statusBox) {
            statusBox.className = 'alert alert-success mb-0 small';
            statusBox.innerHTML = `<i class="fas fa-check-circle me-2"></i>Event ID 9999 injected! CPU: ${res.cpu_pct}%. Pop-up will appear on Dashboard within 5 seconds.`;
          }
          // Navigate to dashboard so user can see the popup appear
          document.querySelector('a[href="#dashboardTab"]').click();
          // Show the popup immediately without waiting for the next poll
          showLiveAlert({
            id:          res.event_row_id,
            event_id:    res.event_id,
            source:      res.source,
            category:    'High CPU Alert',
            severity:    'High',
            message:     res.message,
            description: res.message,
            timestamp:   res.timestamp,
            rule_id:     res.rule_id,
            alert_type:  'highcpu',
            remediated:  false,
          });
        }
      } catch (e) {
        if (statusBox) { statusBox.className = 'alert alert-danger mb-0 small'; statusBox.innerHTML = `<i class="fas fa-exclamation-circle me-2"></i>Injection failed: ${e.message}`; }
        console.error('Inject HighCPU from sim failed:', e);
      }
      if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-bolt me-1"></i>Inject High CPU Error'; }
    }

    // Called from the Simulation tab Service Crash inject button
    async function injectServiceCrashFromSim() {
      const btn = document.getElementById('servicecrash-inject-btn');
      const statusBox = document.getElementById('servicecrash-sim-status-box');
      if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Injecting...'; }
      if (statusBox) { statusBox.className = 'alert alert-warning mb-0 small'; statusBox.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Writing to Windows Event Log and registering event...'; }
      try {
        const res = await api('/api/simulations/servicecrash/inject', { method: 'POST', headers: {'Content-Type':'application/json'}, body: '{}' });
        if (res.status === 'ok') {
          if (statusBox) {
            statusBox.className = 'alert alert-success mb-0 small';
            statusBox.innerHTML = `<i class="fas fa-check-circle me-2"></i>Event ID 7034 injected! PrintSpooler crashed ${res.crash_count} time(s). Pop-up will appear on Dashboard within 5 seconds.`;
          }
          document.querySelector('a[href="#dashboardTab"]').click();
          showLiveAlert({
            id:          res.event_row_id,
            event_id:    res.event_id,
            source:      res.source,
            category:    'Service Crash',
            severity:    'High',
            message:     res.message,
            description: res.message,
            timestamp:   res.timestamp,
            rule_id:     res.rule_id,
            alert_type:  'servicecrash',
            remediated:  false,
          });
        }
      } catch (e) {
        if (statusBox) { statusBox.className = 'alert alert-danger mb-0 small'; statusBox.innerHTML = `<i class="fas fa-exclamation-circle me-2"></i>Injection failed: ${e.message}`; }
        console.error('Inject ServiceCrash from sim failed:', e);
      }
      if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-bolt me-1"></i>Inject Service Crash Error'; }
    }

    // Core function: renders and shows the live alert popup
    function showLiveAlert(alert) {
      if (_lapDismissedIds.has(alert.id)) return;  // already dismissed this session

      _lapEventRowId = alert.id;
      _lapRuleId     = alert.rule_id;
      _lapAlertType  = alert.alert_type || 'highcpu';

      const popup    = document.getElementById('live-alert-popup');
      const header   = document.getElementById('live-alert-popup-header');
      const icon     = document.getElementById('lap-icon');
      const title    = document.getElementById('lap-title');
      const subtitle = document.getElementById('lap-subtitle');
      const msgEl    = document.getElementById('lap-message');
      const tsEl     = document.getElementById('lap-timestamp');
      const cpuBar   = document.getElementById('lap-cpu-bar');
      const cpuPct   = document.getElementById('lap-cpu-pct');
      const actions  = document.getElementById('lap-actions');
      const progWrap = document.getElementById('lap-progress-wrap');
      const remBtn   = document.getElementById('lap-remediate-btn');

      if (!popup) return;

      // Reset state
      progWrap.style.display = 'none';
      actions.style.display  = 'flex';
      remBtn.disabled = false;
      remBtn.innerHTML = '⚡ Auto-Remediate Now';
      popup.classList.remove('remediated-state');

      const isServiceCrash = (_lapAlertType === 'servicecrash');

      if (isServiceCrash) {
        // Orange/amber theme for Service Crash
        header.style.background = 'linear-gradient(135deg,#f7971e,#ffd200)';
        icon.textContent    = '🔧';
        title.textContent   = 'Service Crash Detected';
        subtitle.textContent = `Event 7034 · ${alert.source || 'AutoRemediationDemo'}`;
        cpuBar.style.background = 'linear-gradient(90deg,#f7971e,#ffd200)';
        const cpuVal = Math.floor(Math.random() * 15) + 80;  // fake "service restart" CPU meter
        cpuPct.style.color = '#f7971e';
        cpuPct.textContent = 'Critical';
        cpuBar.style.width = cpuVal + '%';
        document.querySelector('#live-alert-popup > div:first-child').style.boxShadow =
          '0 8px 40px rgba(247,151,30,0.35),0 2px 12px rgba(0,0,0,0.4)';
        popup.style.boxShadow = '0 8px 40px rgba(247,151,30,0.35),0 2px 12px rgba(0,0,0,0.4)';
      } else {
        // Red/orange theme for High CPU (original)
        header.style.background = 'linear-gradient(135deg,#ff4e50,#f9d423)';
        icon.textContent    = '⚠️';
        title.textContent   = 'High CPU Alert Detected';
        subtitle.textContent = `Event 9999 · ${alert.source || 'AutoRemediationDemo'}`;
        cpuBar.style.background = 'linear-gradient(90deg,#fc913a,#ff4e50)';
        const cpuMatch = (alert.message || '').match(/CPU:\s*(\d+)%/);
        const cpuVal = cpuMatch ? parseInt(cpuMatch[1]) : (Math.floor(Math.random()*8)+92);
        cpuPct.style.color = '#fc913a';
        cpuPct.textContent = cpuVal + '%';
        cpuBar.style.width = cpuVal + '%';
        popup.style.boxShadow = '0 8px 40px rgba(255,78,80,0.35),0 2px 12px rgba(0,0,0,0.4)';
      }

      msgEl.textContent = (alert.message || alert.description || '').substring(0, 180);
      tsEl.textContent  = alert.timestamp ? 
        'Detected: ' + new Date(alert.timestamp).toLocaleString() : '';

      if (alert.remediated) {
        // Already remediated — show resolved state
        actions.style.display = 'none';
        popup.classList.add('remediated-state');
        header.style.background = 'linear-gradient(135deg,#28a745,#20c997)';
        icon.textContent  = '✅';
        title.textContent = isServiceCrash ? 'Service Crash Resolved' : 'CPU Alert Resolved';
      }

      popup.style.display = 'block';
      popup.classList.remove('pulsing');
      void popup.offsetWidth;   // force reflow to retrigger animation
      popup.classList.add('pulsing');
    }

    // Polling: every 5 seconds, fetch /api/alerts/live and surface new ones
    async function pollLiveAlerts() {
      try {
        const alerts = await api('/api/alerts/live?window=300');
        if (!Array.isArray(alerts) || alerts.length === 0) return;
        const latest = alerts[0];  // Most-recent first
        if (_lapDismissedIds.has(latest.id)) return;
        // Only open a NEW popup when the event row id changes
        if (_lapEventRowId !== latest.id) {
          showLiveAlert(latest);
        }
      } catch (e) {
        // silently ignore polling errors
      }
    }

    // Called when user clicks "Auto-Remediate Now" in the popup
    async function remediateFromPopup() {
      if (!_lapEventRowId) return;
      const remBtn  = document.getElementById('lap-remediate-btn');
      const progWrap = document.getElementById('lap-progress-wrap');
      const progBar  = document.getElementById('lap-progress-bar');
      const progText = document.getElementById('lap-progress-text');
      const actions  = document.getElementById('lap-actions');
      const popup    = document.getElementById('live-alert-popup');
      const header   = document.getElementById('live-alert-popup-header');
      const title    = document.getElementById('lap-title');
      const icon     = document.getElementById('lap-icon');

      remBtn.disabled = true;
      remBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Remediating...';
      actions.style.display = 'flex';
      progWrap.style.display = 'block';
      progBar.style.width = '0%';
      progText.textContent = 'Executing remediation script...';

      // Animate progress bar
      setTimeout(() => { progBar.style.width = '35%'; }, 100);
      setTimeout(() => { progBar.style.width = '70%'; }, 700);

      try {
        const endpoint = (_lapAlertType === 'servicecrash')
          ? '/api/simulations/servicecrash/remediate'
          : '/api/simulations/highcpu/remediate';

        const res = await api(endpoint, {
          method: 'POST',
          headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ event_row_id: _lapEventRowId })
        });

        progBar.style.width = '100%';

        if (res.status === 'success') {
          progText.textContent = 'Remediation succeeded! Incident resolved.';
          popup.classList.add('remediated-state');
          header.style.background = 'linear-gradient(135deg,#28a745,#20c997)';
          icon.textContent  = '✅';
          title.textContent = (_lapAlertType === 'servicecrash') ?
            'Service Crash Resolved' : 'CPU Alert Resolved';
          actions.style.display = 'none';
          _lapDismissedIds.add(_lapEventRowId);
          // Auto-dismiss after 4s
          setTimeout(() => dismissLiveAlert(), 4000);
        } else {
          progText.textContent = `Remediation status: ${res.status}. Check History tab for output.`;
          remBtn.disabled  = false;
          remBtn.innerHTML = '⚡ Auto-Remediate Now';
        }
      } catch (e) {
        progText.textContent = `Error: ${e.message}`;
        remBtn.disabled  = false;
        remBtn.innerHTML = '⚡ Auto-Remediate Now';
      }

      loadHistory();
      loadDashboard();
      loadFilteredEvents();
    }

    function dismissLiveAlert() {
      const popup = document.getElementById('live-alert-popup');
      if (popup) {
        if (_lapEventRowId) _lapDismissedIds.add(_lapEventRowId);
        popup.style.display = 'none';
        popup.classList.remove('pulsing', 'remediated-state');
        _lapEventRowId = null;
        _lapRuleId     = null;
      }
    }

    // Start polling every 5 seconds
    setInterval(pollLiveAlerts, 5000);

    async function pollMonitorStatus() {
      try {
        const status = await api('/api/monitor/status');
        const pill = document.getElementById('monitor-status-pill');
        const dot = document.getElementById('monitor-dot');
        const lastEl = document.getElementById('monitor-last');
        if (!pill) return;
        if (status.running) {
          dot.style.background = '#198754';
          dot.style.boxShadow = '0 0 6px #198754';
          if (status.last_poll) {
            const timeStr = new Date(status.last_poll).toLocaleTimeString();
            lastEl.textContent = `(Last: ${timeStr})`;
          }
        } else {
          dot.style.background = '#dc3545';
          dot.style.boxShadow = 'none';
          lastEl.textContent = '(Stopped)';
        }
      } catch (e) {
        // ignore silently
      }
    }

    async function loadManualReviewCount() {
      try {
        const rows = await api('/api/events/manual-review');
        const count = rows.length;
        document.getElementById('stat-manual-review').textContent = count;
        const alertRow = document.getElementById('manual-review-alert-row');
        if (alertRow) {
          alertRow.style.setProperty('display', count > 0 ? 'flex' : 'none', 'important');
        }
      } catch (e) {}
    }

    async function dismissReview(eventId) {
      try {
        await api('/api/events/' + eventId + '/dismiss-review', 'POST');
        loadFilteredEvents();
        loadManualReviewCount();
      } catch (e) {
        alert('Failed to dismiss manual review');
      }
    }


    async function loadFilteredEvents() {
      try {
        // Use DB events endpoint so we have confidence_score + dedup_count
        const rows = await api('/api/events');
        displayFilteredEvents(rows);
        const el = document.getElementById('filtered-last-updated');
        if (el && rows && rows.length > 0)
          el.textContent = `Last: ${new Date(rows[0].timestamp).toLocaleString()}`;
      } catch (e) {
        console.error('Failed to load filtered events:', e);
      }
    }

    function displayFilteredEvents(rows) {
      const tbody = document.querySelector('#filtered-events-table tbody');
      if (!tbody) return;
      tbody.innerHTML = '';
      if (!rows || rows.length === 0) {
        tbody.innerHTML = '<tr><td colspan="10" class="text-center text-muted py-3">No events yet.</td></tr>';
        return;
      }
      for (const r of rows) {
        const tr = document.createElement('tr');
        const msg = (r.description || r.message || '').replace(/</g, '&lt;').substring(0, 200);
        const dedup = parseInt(r.dedup_count) || 1;
        const dedupBadge = dedup > 1
          ? `<span class="badge" style="background:#6610f2" title="Last seen: ${r.last_seen || ''}">×${dedup}</span>`
          : `<span class="badge bg-secondary">1</span>`;
        const confBadge = getConfidenceBadge(r.confidence_score);

        let remediatedDisplay = '<span class="badge bg-secondary">Not Remediated</span>';
        if (r.remediated_at) {
          remediatedDisplay = `<small class="text-success"><i class="fas fa-check-circle me-1"></i>${new Date(r.remediated_at).toLocaleString()}</small>`;
        } else if (r.needs_manual_review && !r.dismissed_review) {
          remediatedDisplay = `
            <div class="d-flex flex-column align-items-center gap-1">
              <span class="badge bg-danger"><i class="fas fa-exclamation-triangle me-1"></i>Review Needed</span>
              <button class="btn btn-sm btn-link text-muted p-0" style="font-size:0.75rem" onclick="dismissReview(${r.id})">Dismiss</button>
            </div>
          `;
        }

        tr.innerHTML = `
      <td>${getLevelBadge(r.level)}</td>
      <td style="overflow:hidden; text-overflow:ellipsis;"><code>${r.event_id}</code></td>
      <td style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="${r.source || ''}">${r.source || ''}</td>
      <td>${getSeverityBadge(r.severity)}</td>
      <td class="small" style="overflow:-webkit-paged-y; text-overflow:ellipsis; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; max-height: 4.5em;" title="${(r.message || '').replace(/"/g, '&quot;')}">${msg}</td>
      <td><small class="text-muted">${r.timestamp ? new Date(r.timestamp).toLocaleString() : ''}</small></td>
      <td>${remediatedDisplay}</td>
      <td class="text-center">${confBadge}</td>
      <td class="text-center">${dedupBadge}</td>
      <td class="text-center">
        <div class="d-flex gap-1 justify-content-center flex-wrap">
          <button class="btn btn-sm btn-outline-info" onclick='showMatches(${r.id || JSON.stringify(r)})' title="View matching rules">
            <i class="fas fa-link me-1"></i>Matches
          </button>
          <button class="btn btn-sm btn-outline-primary" onclick='createRuleFromEvent(${JSON.stringify(r)})' title="Create a new rule">
            <i class="fas fa-plus me-1"></i>Rule
          </button>
        </div>
      </td>
    `;
        tbody.appendChild(tr);
      }
    }

    // Toggle Sidebar
    function toggleSidebar() {
      const sidebar = document.getElementById('sidebar');
      const mainContent = document.querySelector('.main-content');

      sidebar.classList.toggle('collapsed');
      mainContent.classList.toggle('sidebar-collapsed');

      // Save state to localStorage
      localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
    }

    // Restore sidebar state on page load
    document.addEventListener('DOMContentLoaded', () => {
      const sidebarCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
      if (sidebarCollapsed) {
        toggleSidebar();
      }
    });

    // Mobile sidebar open/close
    function openMobileSidebar() {
      document.getElementById('sidebar').classList.add('show');
      document.getElementById('sidebarOverlay').classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeMobileSidebar() {
      document.getElementById('sidebar').classList.remove('show');
      document.getElementById('sidebarOverlay').classList.remove('active');
      document.body.style.overflow = '';
    }

    // Close mobile sidebar when a nav link is clicked
    document.querySelectorAll('.nav-sidebar .nav-link').forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 768) closeMobileSidebar();
      });
    });
  </script>

</body>

</html>