<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Auto-Remediation Control Center</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link href="/static/style.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>

<body class="bg-gradient">
  <!-- Sidebar overlay (mobile) -->
  <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeMobileSidebar()"></div>

  <!-- Sidebar Navigation -->
  <nav class="navbar navbar-dark bg-dark-navy sticky-top sidebar" id="sidebar">
    <div class="container-fluid flex-column">
      <!-- Sidebar Toggle Button (inside sidebar) -->
      <button class="sidebar-toggle" id="sidebarToggle" onclick="toggleSidebar()" title="Toggle Sidebar">
        <i class="fas fa-chevron-left"></i>
      </button>

      <div class="navbar-brand mb-4 d-flex align-items-center">
        <i class="fas fa-shield-alt me-2"></i>
        <span class="fw-bold sidebar-text">Remediation Center</span>
      </div>
      <ul class="nav nav-pills flex-column mb-auto nav-sidebar" id="mainTabs">
        <li class="nav-item mb-2">
          <a class="nav-link active rounded-3" data-bs-toggle="tab" href="#dashboardTab">
            <i class="fas fa-tachometer-alt me-2"></i><span class="sidebar-text">Dashboard</span>
          </a>
        </li>
        <li class="nav-item mb-2">
          <a class="nav-link rounded-3" data-bs-toggle="tab" href="#filteredEventsTab">
            <i class="fas fa-exclamation-triangle me-2"></i><span class="sidebar-text">Warnings & Errors</span>
          </a>
        </li>
        <li class="nav-item mb-2">
          <a class="nav-link rounded-3" data-bs-toggle="tab" href="#rulesTab">
            <i class="fas fa-cogs me-2"></i><span class="sidebar-text">Rules</span>
          </a>
        </li>
        <li class="nav-item mb-2">
          <a class="nav-link rounded-3" data-bs-toggle="tab" href="#approvalsTab">
            <i class="fas fa-check-circle me-2"></i><span class="sidebar-text">Approvals</span>
          </a>
        </li>
        <li class="nav-item mb-2">
          <a class="nav-link rounded-3" data-bs-toggle="tab" href="#historyTab">
            <i class="fas fa-history me-2"></i><span class="sidebar-text">History</span>
          </a>
        </li>
        <li class="nav-item mb-2">
          <a class="nav-link rounded-3" data-bs-toggle="tab" href="#simulationTab">
            <i class="fas fa-flask me-2"></i><span class="sidebar-text">Simulation</span>
          </a>
        </li>
      </ul>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="main-content">
    <!-- Top Header -->
    <header class="header-top">
      <div class="d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
          <button class="mobile-menu-btn" id="mobileMenuBtn" onclick="openMobileSidebar()" title="Menu">
            <i class="fas fa-bars"></i>
          </button>
          <div>
            <h2 class="mb-0">Auto-Remediation Control Center</h2>
            <p class="text-muted mb-0 small">Automated system remediation and management</p>
          </div>
        </div>
        <div class="d-flex gap-2 align-items-center">
          <!-- Live Monitor Status Pill -->
          <div id="monitor-status-pill" class="d-flex align-items-center gap-2 px-3 py-1 rounded-pill" style="background:rgba(255,255,255,0.08);font-size:0.78rem;cursor:default;" title="Windows Event Log Monitor">
            <span id="monitor-dot" style="width:9px;height:9px;border-radius:50%;background:#6c757d;display:inline-block;"></span>
            <span id="monitor-label" class="text-muted">Event Monitor</span>
            <span id="monitor-last" class="text-muted" style="font-size:0.72rem;"></span>
          </div>
          <button class="btn btn-sm btn-light" onclick="refreshAll()">
            <i class="fas fa-sync me-1"></i>Refresh All
          </button>
          <button class="btn btn-sm btn-danger" id="inject-error-btn" onclick="injectHighCpuAlert()" title="Inject a simulated High CPU Alert to test the live detection pipeline">
            <i class="fas fa-bolt me-1"></i>Inject Error
          </button>
        </div>
      </div>
    </header>

    <div class="container-fluid p-4">
      <div class="tab-content">
        <!-- Dashboard Tab -->
        <div class="tab-pane fade show active" id="dashboardTab">
          <!-- Statistics Cards -->
          <div class="row mb-4">
            <div class="col-md-3">
              <div class="card card-modern border-start border-primary border-4">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted mb-1">Errors & Warnings</h6>
                      <h2 class="mb-0" id="stat-total-events">0</h2>
                    </div>
                    <div class="text-warning">
                      <i class="fas fa-exclamation-triangle fa-2x"></i>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card card-modern border-start border-success border-4">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted mb-1">Active Rules</h6>
                      <h2 class="mb-0" id="stat-total-rules">0</h2>
                    </div>
                    <div class="text-success">
                      <i class="fas fa-cogs fa-2x"></i>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card card-modern border-start border-warning border-4">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted mb-1">Pending Approvals</h6>
                      <h2 class="mb-0" id="stat-pending-approvals">0</h2>
                    </div>
                    <div class="text-warning">
                      <i class="fas fa-clock fa-2x"></i>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="card card-modern border-start border-info border-4">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center">
                    <div>
                      <h6 class="text-muted mb-1">Remediations</h6>
                      <h2 class="mb-0" id="stat-total-remediations">0</h2>
                    </div>
                    <div class="text-info">
                      <i class="fas fa-history fa-2x"></i>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Manual Review Alert Card (shown when review count > 0) -->
          <div id="manual-review-alert-row" class="row mb-3" style="display:none!important">
            <div class="col-12">
              <div class="card border-danger" style="background:rgba(220,53,69,0.10);border-radius:12px;">
                <div class="card-body py-2 px-3">
                  <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-3">
                      <i class="fas fa-exclamation-circle text-danger fa-xl"></i>
                      <div>
                        <h6 class="mb-0 text-danger fw-bold">Manual Review Required</h6>
                        <small class="text-muted"><span id="stat-manual-review">0</span> event(s) have no matching remediation rule — human action needed</small>
                      </div>
                    </div>
                    <button onclick="document.querySelector('a[href=\'#filteredEventsTab\']').click()" class="btn btn-sm btn-danger">
                      <i class="fas fa-eye me-1"></i>View Events
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Charts Row -->
          <div class="row mb-4">
            <div class="col-md-6">
              <div class="card card-modern">
                <div class="card-header bg-gradient-primary border-0">
                  <h5 class="mb-0 text-white"><i class="fas fa-chart-pie me-2"></i>Events by Severity</h5>
                </div>
                <div class="card-body">
                  <canvas id="severityChart" height="200"></canvas>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="card card-modern">
                <div class="card-header bg-gradient-success border-0">
                  <h5 class="mb-0 text-white"><i class="fas fa-chart-bar me-2"></i>Events by Category</h5>
                </div>
                <div class="card-body">
                  <canvas id="categoryChart" height="200"></canvas>
                </div>
              </div>
            </div>
          </div>

          <!-- Recent Activity -->
          <div class="row">
            <div class="col-md-6">
              <div class="card card-modern">
                <div class="card-header bg-gradient-info border-0">
                  <h5 class="mb-0 text-white"><i class="fas fa-clock me-2"></i>Recent Events</h5>
                </div>
                <div class="card-body p-0">
                  <div class="list-group list-group-flush" id="recent-events-list">
                    <div class="list-group-item text-center text-muted">Loading...</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="card card-modern">
                <div class="card-header bg-gradient-secondary border-0">
                  <h5 class="mb-0 text-white"><i class="fas fa-tasks me-2"></i>Recent Remediations</h5>
                </div>
                <div class="card-body p-0">
                  <div class="list-group list-group-flush" id="recent-remediations-list">
                    <div class="list-group-item text-center text-muted">Loading...</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Intelligence Summary Card -->
          <div class="row mb-4">
            <div class="col-12">
              <div class="card card-modern" style="border-left: 4px solid #9d4edd;">
                <div class="card-header border-0 d-flex justify-content-between align-items-center"
                     style="background:linear-gradient(135deg,rgba(157,78,221,0.2),rgba(100,50,180,0.1));">
                  <h5 class="mb-0 text-white">
                    <i class="fas fa-brain me-2" style="color:#c77dff"></i>Alert Intelligence Summary
                  </h5>
                  <small class="text-muted">Auto-updated every 5s</small>
                </div>
                <div class="card-body">
                  <div class="row g-3 text-center">
                    <div class="col-6 col-md-3">
                      <div class="p-3" style="background:rgba(157,78,221,0.1);border-radius:12px;border:1px solid rgba(157,78,221,0.3);">
                        <div class="fw-bold" style="font-size:1.8rem;color:#c77dff" id="intel-total-events">—</div>
                        <div class="text-muted small">Total Unique Events</div>
                      </div>
                    </div>
                    <div class="col-6 col-md-3">
                      <div class="p-3" style="background:rgba(0,212,255,0.1);border-radius:12px;border:1px solid rgba(0,212,255,0.3);">
                        <div class="fw-bold" style="font-size:1.8rem;color:#00d4ff" id="intel-suppressed">—</div>
                        <div class="text-muted small">Duplicate Occurrences Collapsed</div>
                      </div>
                    </div>
                    <div class="col-6 col-md-3">
                      <div class="p-3" style="background:rgba(255,170,0,0.1);border-radius:12px;border:1px solid rgba(255,170,0,0.3);">
                        <div class="fw-bold" style="font-size:1.8rem;color:#ffaa00" id="intel-avg-confidence">—</div>
                        <div class="text-muted small">Avg Confidence Score</div>
                      </div>
                    </div>
                    <div class="col-6 col-md-3">
                      <div class="p-3" style="background:rgba(74,158,255,0.1);border-radius:12px;border:1px solid rgba(74,158,255,0.3);">
                        <div class="fw-bold" style="font-size:1.8rem;color:#4a9eff" id="intel-cooldown-rules">—</div>
                        <div class="text-muted small">Rules with Cooldown</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Recent Activity -->
          <div class="row">
            <div class="col-md-6">
              <div class="card card-modern">
                <div class="card-header bg-gradient-info border-0">
                  <h5 class="mb-0 text-white"><i class="fas fa-clock me-2"></i>Recent Events</h5>
                </div>
                <div class="card-body p-0">
                  <div class="list-group list-group-flush" id="recent-events-list">
                    <div class="list-group-item text-center text-muted">Loading...</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-6">
              <div class="card card-modern">
                <div class="card-header bg-gradient-secondary border-0">
                  <h5 class="mb-0 text-white"><i class="fas fa-tasks me-2"></i>Recent Remediations</h5>
                </div>
                <div class="card-body p-0">
                  <div class="list-group list-group-flush" id="recent-remediations-list">
                    <div class="list-group-item text-center text-muted">Loading...</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Filtered Warnings & Errors -->
        <div class="tab-pane fade p-3" id="filteredEventsTab">
          <div class="card card-modern">
            <div class="card-header bg-gradient-warning border-0 d-flex justify-content-between align-items-center">
              <h5 class="mb-0 text-white">
                <i class="fas fa-exclamation-triangle me-2"></i>Warnings & Errors (Filtered)
                <small class="text-white-50 ms-2" id="filtered-last-updated"></small>
              </h5>
              <button class="btn btn-sm btn-light" onclick="loadFilteredEvents()">
                <i class="fas fa-sync me-1"></i>Refresh
              </button>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0" id="filtered-events-table" style="table-layout: fixed; width: 100%;">
                  <thead class="table-light">
                    <tr>
                      <th style="width: 6%">Level</th>
                      <th style="width: 8%">Event ID</th>
                      <th style="width: 12%">Source</th>
                      <th style="width: 8%">Severity</th>
                      <th style="width: 26%">Message / Description</th>
                      <th style="width: 10%">Timestamp</th>
                      <th style="width: 12%">Remediated</th>
                      <th style="width: 6%" class="text-center">
                        <i class="fas fa-brain" style="color:#c77dff" title="Alert Intelligence"></i><br>Conf
                      </th>
                      <th style="width: 4%" class="text-center">Dedup</th>
                      <th style="width: 8%" class="text-center">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td colspan="10" class="text-center text-muted py-3">No warnings or errors yet</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Rules Tab -->
        <div class="tab-pane fade" id="rulesTab">
          <div class="row">
            <div class="col-12">
              <div class="card card-modern">
                <div
                  class="card-header bg-gradient-success border-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
                  <h5 class="mb-0 text-white">
                    <i class="fas fa-list me-2"></i>Active Rules
                  </h5>
                  <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-sm btn-light" onclick="openNewRuleModal()">
                      <i class="fas fa-plus me-1"></i>New Rule
                    </button>
                    <button class="btn btn-sm btn-light" onclick="populateRulesFromJSON()">
                      <i class="fas fa-download me-1"></i>Import from JSON
                    </button>
                  </div>
                </div>
                <div class="card-body p-0">
                  <div class="table-responsive">
                    <table class="table table-hover mb-0" id="rules-table">
                      <thead class="table-light">
                        <tr>
                          <th style="min-width:160px">Rule Name</th>
                          <th style="min-width:70px" class="text-center" title="Lower = higher priority">Priority</th>
                          <th style="min-width:150px">Criteria</th>
                          <th style="min-width:90px">Severity</th>
                          <th style="min-width:65px">Auto</th>
                          <th style="min-width:85px" class="text-center" title="Cooldown suppression window">Cooldown</th>
                          <th style="min-width:220px" class="text-center">Actions</th>
                        </tr>
                      </thead>
                      <tbody></tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Approvals Tab -->
        <div class="tab-pane fade" id="approvalsTab">
          <div class="card card-modern">
            <div class="card-header bg-gradient-warning border-0">
              <h5 class="mb-0 text-white">
                <i class="fas fa-check-circle me-2"></i>Pending Approval Requests
              </h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0" id="approvals-table">
                  <thead class="table-light">
                    <tr>
                      <th style="width: 8%">ID</th>
                      <th style="width: 12%">Event ID</th>
                      <th style="width: 18%">Rule</th>
                      <th style="width: 15%">Requested By</th>
                      <th style="width: 18%">Requested At</th>
                      <th style="width: 12%">Status</th>
                      <th style="width: 17%" class="text-center">Actions</th>
                    </tr>
                  </thead>
                  <tbody></tbody>
                </table>
              </div>
              <div class="alert alert-info m-3 mb-0" style="display: none;" id="no-approvals">
                <i class="fas fa-info-circle me-2"></i>No pending approval requests
              </div>
            </div>
          </div>
        </div>

        <!-- History Tab -->
        <div class="tab-pane fade" id="historyTab">
          <div class="card card-modern">
            <div class="card-header bg-gradient-secondary border-0">
              <h5 class="mb-0 text-white">
                <i class="fas fa-history me-2"></i>Remediation History
              </h5>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover mb-0" id="history-table">
                  <thead class="table-light">
                    <tr>
                      <th style="width: 8%">ID</th>
                      <th style="width: 12%">Event ID</th>
                      <th style="width: 18%">Rule</th>
                      <th style="width: 12%">Status</th>
                      <th style="width: 30%">Output</th>
                      <th style="width: 15%">Event Time</th>
                      <th style="width: 15%">Remediation Time</th>
                    </tr>
                  </thead>
                  <tbody></tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Simulation Tab -->
        <div class="tab-pane fade" id="simulationTab">
          <div class="card card-modern mb-4">
            <div class="card-header bg-gradient-secondary border-0">
              <h5 class="mb-0 text-white">
                <i class="fas fa-flask me-2"></i>Select Simulation Type
              </h5>
            </div>
            <div class="card-body">
              <div class="row g-3 align-items-end">
                <div class="col-md-3">
                  <label class="form-label fw-500">Choose Simulation:</label>
                  <select id="simulation-type-selector" class="form-select form-control-modern" onchange="switchSimulation(this.value)">
                    <option value="crash">Event 1000 - Application Crash</option>
                    <option value="diskspace">Event 2013 - Low Disk Space</option>
                    <option value="eventlog">Event 1100 - Event Log Shutdown</option>
                    <option value="auditevents">Event 1101 - Audit Events Dropped</option>
                    <option value="highcpu">Event 9999 - High CPU Alert &#9889;</option>
                    <option value="servicecrash">Event 7034 - Service Crash &#x1F6A8;</option>
                  </select>
                </div>
              </div>
            </div>
          </div>

          <div class="row g-4">
            <div class="col-lg-4">
              <!-- Crash Lab Controls -->
              <div class="card card-modern h-100" id="crashLabCard">
                <div class="card-header bg-gradient-primary border-0">
                  <h5 class="mb-0 text-white">
                    <i class="fas fa-flask me-2"></i>Crash Lab Controls
                  </h5>
                </div>
                <div class="card-body d-flex flex-column gap-3">
                  <div class="small text-muted">
                    Simulates a realistic <strong>Event ID 1000 Application Crash</strong>, injects it into the remediation engine, and auto-runs the configured fix script.
                  </div>
                  <div>
                    <label class="form-label fw-500" for="simulation-app-name">Application Name</label>
                    <input type="text" id="simulation-app-name" class="form-control form-control-modern" value="DemoCrashApp" />
                  </div>
                  <div>
                    <label class="form-label fw-500" for="simulation-module">Faulting Module</label>
                    <input type="text" id="simulation-module" class="form-control form-control-modern" value="ntdll.dll" />
                  </div>
                  <div>
                    <label class="form-label fw-500" for="simulation-exception">Exception Code</label>
                    <input type="text" id="simulation-exception" class="form-control form-control-modern" value="0xc0000005" />
                  </div>
                  <div>
                    <label class="form-label fw-500" for="simulation-count">Simulated Events</label>
                    <input type="number" id="simulation-count" class="form-control form-control-modern" min="1" max="5" value="1" />
                  </div>
                  <div>
                    <label class="form-label fw-500" for="simulation-profile">Incident Profile</label>
                    <select id="simulation-profile" class="form-select form-control-modern">
                      <option value="stable">Stable (quick recovery)</option>
                      <option value="degraded" selected>Degraded (intermittent crashes)</option>
                      <option value="critical">Critical (persistent crash loop)</option>
                    </select>
                  </div>
                  <div class="d-flex flex-column gap-2">
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="simulation-retry" checked />
                      <label class="form-check-label" for="simulation-retry">Enable auto-retry on failed recovery</label>
                    </div>
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" id="simulation-verify" checked />
                      <label class="form-check-label" for="simulation-verify">Verify recovery after each attempt</label>
                    </div>
                  </div>
                  <div class="small">
                    <div class="mb-1"><strong>Script:</strong> <code>remediation_scripts/Error1000_ApplicationCrash.ps1</code></div>
                    <div><strong>Fix Command:</strong> <code id="sim-fix-command">sfc /scannow</code></div>
                  </div>
                  <button class="btn btn-primary btn-modern" id="sim-run-btn" onclick="runError1000Simulation()">
                    <i class="fas fa-play me-1"></i>Run Simulation
                  </button>
                  <div class="sim-playback-controls">
                    <div class="form-check mb-2">
                      <input class="form-check-input" type="checkbox" id="simulation-live-playback" checked />
                      <label class="form-check-label" for="simulation-live-playback">Live step-by-step playback</label>
                    </div>
                    <label class="form-label fw-500 mb-1" for="simulation-playback-speed">Playback Speed</label>
                    <select id="simulation-playback-speed" class="form-select form-control-modern form-select-sm">
                      <option value="1.35">Fast</option>
                      <option value="1" selected>Normal</option>
                      <option value="0.7">Detailed</option>
                    </select>
                  </div>
                  <div class="alert alert-info mb-0 small" id="sim-status-box">
                    <i class="fas fa-info-circle me-2"></i>
                    Waiting to run simulation.
                  </div>
                </div>
              </div>

              <!-- Low Disk Space Lab Controls -->
              <div class="card card-modern h-100" id="diskLabCard" style="display:none;">
