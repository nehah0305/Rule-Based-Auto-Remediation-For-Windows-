                <div class="card-body">
                  <div style="border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:20px;background:rgba(0,0,0,0.2);">
                    <div class="mb-3 text-center">
                      <div class="small text-muted mb-2">Live CPU Utilisation</div>
                      <div style="position:relative;display:inline-block;width:160px;height:80px;overflow:hidden;">
                        <svg viewBox="0 0 160 80" width="160" height="80">
                          <path d="M 10 80 A 70 70 0 0 1 150 80" stroke="rgba(255,255,255,0.12)" stroke-width="16" fill="none" stroke-linecap="round"/>
                          <path id="highcpu-gauge-arc" d="M 10 80 A 70 70 0 0 1 150 80" stroke="#6c757d" stroke-width="16" fill="none" stroke-linecap="round"
                                stroke-dasharray="220" stroke-dashoffset="220" style="transition:stroke-dashoffset 0.8s ease,stroke 0.5s ease;"/>
                        </svg>
                        <div style="position:absolute;bottom:0;left:50%;transform:translateX(-50%);text-align:center;">
                          <div id="highcpu-gauge-pct" style="font-size:1.6rem;font-weight:700;color:#6c757d;line-height:1;">--%</div>
                          <div class="small text-muted" style="font-size:0.65rem;">CPU USAGE</div>
