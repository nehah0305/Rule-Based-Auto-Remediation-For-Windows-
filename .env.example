# Flask Backend Configuration
# Copy this file to .env and adjust as needed.
# If port 5000 is taken on your machine, change FLASK_PORT and start the
# desktop app with:  .\run_frontend.ps1 -ApiUrl http://localhost:<your port>
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# API Configuration
# Use localhost for same machine, or the server's IP address for remote access
# Examples:
#   - Same machine: http://localhost:5000
#   - Remote server: http://192.168.1.100:5000
#   - Remote server with custom port: http://192.168.1.100:8080
API_BASE_URL=http://localhost:5000

# Database Configuration
# Leave empty to use default location (backend/rules.db)
DATABASE_PATH=

# Event Monitor Configuration
POLL_INTERVAL_SECONDS=10
MAX_EVENTS_PER_POLL=100
HISTORICAL_DAYS=30
MAX_HISTORICAL_EVENTS=10000

# Event Logs to Monitor (comma-separated)
LOG_NAMES=System,Application

# Specific Event IDs to Monitor (comma-separated, leave empty for all)
# Example: 7031,7034,1000,1001
EVENT_IDS_TO_MONITOR=

# ── Task Scheduler Mode ────────────────────────────────────────────────────────
# Set to true AFTER running remediation_scripts/Setup_EventTriggers.ps1
# When true, Flask becomes a pure API server (no background polling thread).
# Windows Task Scheduler + backend/cli_process_event.py handle all detection.
# When false (default), the built-in background polling thread is used instead.
USE_TASK_SCHEDULER=false
